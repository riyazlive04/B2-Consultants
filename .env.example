# ── Core (required) ──────────────────────────────────────────────
# Runtime connection. On Neon use the POOLED endpoint (host contains "-pooler").
DATABASE_URL="postgresql://b2:b2@localhost:5435/b2_dashboard?schema=public"
# Direct (non-pooled) connection used by `prisma migrate deploy` at build time.
# On Neon use the DIRECT endpoint (host WITHOUT "-pooler"); locally it's the same as DATABASE_URL.
# Must be set on Vercel too, or the build's migrate step fails.
DIRECT_URL="postgresql://b2:b2@localhost:5435/b2_dashboard?schema=public"
# Generate with: openssl rand -hex 32 — never ship the placeholder
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ── FX (live ECB rates via frankfurter.app; cached daily) ────────
FX_API_URL="https://api.frankfurter.app"

# ── Ingest layer (OPTIONAL — off by default; manual core needs none of these) ──
REDIS_URL="redis://localhost:6379"
INGEST_ENABLED="false"

# ── Wave-1: Synamate in-sourcing — public booking + lead-capture webhooks ──
# Booking page is served at ${BETTER_AUTH_URL}/book (no keys needed).
# Meta Lead Ads webhook  → POST /api/leads/meta   (GET verify uses META_VERIFY_TOKEN)
META_VERIFY_TOKEN=""          # any string you also paste into the Meta webhook setup
META_APP_SECRET=""            # Meta app secret — verifies X-Hub-Signature-256 on POSTs
META_PAGE_ACCESS_TOKEN=""     # page token used to fetch lead field_data from the Graph API
META_GRAPH_VERSION="v19.0"
# FlexiFunnels / landing-page webhook → POST /api/leads/flexifunnels
# Send the secret as header  x-webhook-secret: <value>  or query  ?key=<value>
FLEXIFUNNELS_WEBHOOK_SECRET=""
# Pabbly Connect relay → POST /api/leads/pabbly   (same secret conventions as above)
# Pabbly fans each opt-in out to Synamate AND to us; add it as a second action on the
# existing Pabbly workflow. Origin travels in the payload as `lead_source` (facebook / ig /
# youtube / landing_page / …) and maps onto LeadSource; unmapped values land as OTHER.
# Both routes FAIL CLOSED (503) while their secret is blank.
PABBLY_WEBHOOK_SECRET=""

# ── Email via Resend (OFF by default; nothing sends until set) ──
# Same seam as WATI: SECRETS here, non-secret config (from name/address, pause) in the
# Conversations → Settings UI. Sending needs ALL THREE: EMAIL_ENABLED=true, a RESEND_API_KEY,
# and a From address saved in that UI. Miss any one and every email path silently no-ops.
#
# What email is used for, so you know what breaks while it's off:
#   · Password reset ("Forgot password" does nothing without this)
#   · The Outreach SOP's Step 1 opt-in alert to the specialist
#   · Invoice / payment emails
#   · Conversations (the email side of the shared inbox)
#
# The From address must be on a domain you have VERIFIED in Resend — an unverified sender is
# Resend's most common rejection, and it fails at send time, not at save time.
EMAIL_ENABLED="false"         # "true" to arm outbound email at all
RESEND_API_KEY=""             # Resend API key (Bearer) — https://resend.com/api-keys

# ── SMS via Twilio (OFF by default) ──
SMS_ENABLED="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# ── Wave-2: WhatsApp reminders via WATI (OFF by default; nothing sends until set) ──
# Secrets live here; non-secret config (templates, cadence, pause) is edited in the /whatsapp UI.
WATI_ENABLED="false"          # "true" to arm outbound sending at all
WATI_API_ENDPOINT=""          # tenant base URL, e.g. https://live-mt-server.wati.io/{tenantId}
WATI_ACCESS_TOKEN=""          # Bearer access token from the WATI dashboard
WATI_WEBHOOK_SECRET=""        # shared secret for POST /api/wati/webhook (status + replies)
# ── Scheduled triggers (the app has NO internal clock — nothing runs without these) ──
# One secret guards all three cron routes. Send it as header  x-cron-secret: <value> ,
# Authorization: Bearer <value> , or  ?key=<value> . Unset → every route returns 503.
#
#   /api/cron/whatsapp    ~every 15 min — WATI reminder cadence
#   /api/cron/workflows   ~every 5-15 min — automation WAIT steps
#   /api/cron/outreach    EVERY MINUTE — the Outreach SOP engine
#
# The outreach route is the odd one out on purpose: cron cadence IS its timing resolution, and the
# SOP's Step 2 reaction window is 5 minutes. A 15-minute cron cannot police a 5-minute SLA.
CRON_SECRET=""

# ── Agreements (e-signature) ──
# A student's signature is bound to their identity by a one-time code sent to the WhatsApp number
# on the agreement. Until an AGREEMENT_OTP template is approved by Meta and mapped in /whatsapp,
# that code cannot be delivered and no agreement can be signed.
#
# For LOCAL testing only, the flag below shows the code on the signing page instead of sending it.
# It is fail-closed: it needs BOTH this flag AND a localhost BETTER_AUTH_URL, so setting it on a
# real deployment does nothing. Leave it unset. Enabling it in production would reduce the whole
# signature guarantee to "someone had the link".
AGREEMENT_OTP_DEV_ECHO=""     # "true" + localhost BETTER_AUTH_URL → reveal the code in the UI

# Synamate (legacy import only — being replaced by the above) — pending Ameen sign-off
SYNAMATE_API_URL=""
SYNAMATE_API_KEY=""

# Razorpay (income) — pending Ameen sign-off
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Google Sheets (sales-metrics migration source) — pending Ameen sign-off
GOOGLE_SHEETS_CLIENT_EMAIL=""
GOOGLE_SHEETS_PRIVATE_KEY=""
GOOGLE_SHEETS_SPREADSHEET_ID=""

