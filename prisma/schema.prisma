// B2 Consultants Founder Dashboard — FULL 3-PHASE SCHEMA (scoped upfront in Phase 0).
// Phase 1: Finance + Pipeline · Phase 2: People + Students · Phase 3: Funnel + Cash Health.
// Rules baked in (CONTEXT §6):
//  - Money is stored as integer minor units (paise / cents) in BigInt, INR and EUR side by side,
//    with the FX rate used stamped on each record.
//  - Ingestable entities carry `source` + `manualOverride` + `externalRef` (de-dupe).
//  - Audit tables (MilestoneLog, SignalChangeLog, DailyLog, LeadStageHistory) are APPEND-ONLY:
//    no update/delete is exposed at the service layer, ever.
//  - Dates stored UTC, displayed IST DD/MM/YYYY (presentation concern).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries use DATABASE_URL (on Neon: the pooled -pooler endpoint).
  // Migrations (`prisma migrate deploy`) use DIRECT_URL — Neon's direct, non-pooled
  // endpoint — because migrate needs session-level advisory locks PgBouncer can't hold.
  // Locally both point at the same Docker Postgres (see .env).
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ───────────────────────────── Auth (Better Auth) ─────────────────────────────

enum Role {
  ADMIN // Ameen — everything
  HEAD // Karthick — own daily log, view-only Students
  USER // Asma / Nilofer — own daily log + own pipeline entry
  STUDENT // portal login linked to ONE Student record — sees only their own journey
  TUTOR // German Note tutor — GN section only (batches they teach + community)
}

// A suspended account cannot sign in, and its live sessions are deleted the moment
// it is suspended — the badge in Users & access is not decorative.
enum UserStatus {
  ACTIVE
  SUSPENDED
}

model User {
  id            String     @id
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  role          Role       @default(USER)
  status        UserStatus @default(ACTIVE)
  // Per-user feature overrides (Admin-managed): { "finance": true, "students": false, … }.
  // Missing key → the role's default access applies. Admins always see everything.
  sectionAccess Json?
  // Per-user capability overrides: { "finance.write": true, … }. What they may DO, as
  // opposed to which screens they may open. See src/lib/capabilities.ts.
  capabilities  Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sessions                 Session[]
  accounts                 Account[]
  teamProfile              TeamProfile?
  studentProfile           Student?           @relation("StudentAccount")
  incomesEntered           Income[]           @relation("IncomeEnteredBy")
  expensesEntered          Expense[]          @relation("ExpenseEnteredBy")
  leadsEntered             Lead[]             @relation("LeadEnteredBy")
  leadsAssigned            Lead[]             @relation("LeadAssignedTo")
  outcomesEntered          DiscoveryOutcome[] @relation("OutcomeEnteredBy")
  callsLogged              CallLog[]          @relation("CallLoggedBy")
  stageChanges             LeadStageHistory[] @relation("StageChangedBy")
  slotsAssigned            AppointmentSlot[]  @relation("SlotAssignedTo")
  dailyLogs                DailyLog[]
  milestoneLogUpdates      MilestoneLog[]     @relation("MilestoneUpdatedBy")
  signalChanges            SignalChangeLog[]  @relation("SignalChangedBy")
  sprintWeeksEntered       SprintWeek[]       @relation("SprintEnteredBy")
  rewardGrantsDecided      RewardGrant[]      @relation("RewardGrantDecidedBy")
  invite                   UserInvite?        @relation("UserInviteFor")
  invitesCreated           UserInvite[]       @relation("UserInviteCreatedBy")
  gnBatchesTutored         GnBatch[]          @relation("GnBatchTutor")
  gnRecordingsPosted       GnRecording[]      @relation("GnRecordingPostedBy")
  gnRecordingWatches       GnRecordingWatch[] @relation("GnRecordingWatchUser")
  gnEventsCreated          GnEvent[]          @relation("GnEventCreatedBy")
  gnPosts                  GnPost[]           @relation("GnPostAuthor")
  gnComments               GnComment[]        @relation("GnCommentAuthor")
  gnLikes                  GnLike[]           @relation("GnLikeUser")
  gnCommentLikes           GnCommentLike[]    @relation("GnCommentLikeUser")
  telecallerPayoutsEntered TelecallerPayout[] @relation("TelecallerPayoutEnteredBy")
  whatsappMessagesSent     WhatsAppMessage[]  @relation("WhatsAppSentBy")
  agreementsIssued         Agreement[]        @relation("AgreementIssuedBy")
  journalEntriesPosted     JournalEntry[]     @relation("JournalEntryPostedBy")
  periodLocksSet           PeriodLock[]       @relation("PeriodLockedBy")
  auditEntries             AuditEntry[]       @relation("AuditActor")
  activityLogged           ActivityLog[]      @relation("ActivityActor")
  // Synamate CRM (Phase 1)
  companiesOwned           Company[]          @relation("CompanyOwner")
  contactNotes             ContactNote[]      @relation("NoteAuthor")
  tasksAssigned            ContactTask[]      @relation("TaskAssignee")
  tasksCreated             ContactTask[]      @relation("TaskCreatedBy")
  opportunitiesOwned       Opportunity[]      @relation("OppOwner")
  // Synamate Sites (Phase 2)
  formsCreated             Form[]             @relation("FormCreatedBy")
  funnelsCreated           Funnel[]           @relation("FunnelCreatedBy")
  // Synamate Payments (Phase 3)
  invoicesCreated          Invoice[]          @relation("InvoiceCreatedBy")
  invoicePaymentsRecorded  InvoicePayment[]   @relation("InvoicePaymentRecordedBy")
  // Synamate Conversations (Phase 4)
  messagesSent             Message[]          @relation("MessageSentBy")
  messagesAssigned         Message[]          @relation("MessageAssignedTo")
  // Synamate Automation (Phase 5)
  workflowsCreated         Workflow[]         @relation("WorkflowCreatedBy")
  // Outreach Specialist SOP
  outreachStepsActed       OutreachStepLog[]  @relation("OutreachStepActedBy")
  outreachQualified        OutreachJourney[]  @relation("OutreachQualifiedBy")
  outreachTouchpoints      OutreachJourney[]  @relation("OutreachRespTouchpoint")
  outreachDiscos           OutreachJourney[]  @relation("OutreachRespDisco")
  enrollmentsClosed        Enrollment[]       @relation("EnrollmentCloser")
  sssSlotsOwned            SssSlot[]          @relation("SssSlotOwner")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ───────────────────────────── Shared enums ─────────────────────────────

// Ingest provenance (CONTEXT §4). MANUAL is the guaranteed core; everything else is additive.
// Wave-1 (Synamate in-sourcing): BOOKING_FORM = our own public booking page;
// META_LEAD_AD / FLEXIFUNNELS = the two external lead-capture webhooks that replace
// Synamate's lead inbox. SYNAMATE stays only so historical imported rows keep their tag.
//
// Source answers "which pipe carried this row to us", NOT "where did the human come from" —
// that is LeadSource. PABBLY is a relay: it fans the same opt-in out to Synamate and to us,
// so a PABBLY row's LeadSource is whatever origin the payload declares (Meta ad, IG, …).
enum Source {
  MANUAL
  SYNAMATE
  RAZORPAY
  SHEET
  FATHOM
  BOOKING_FORM
  META_LEAD_AD
  FLEXIFUNNELS
  NATIVE_FORM // Phase 2: our own hosted forms / funnel opt-ins (Synamate Sites parity)
  PABBLY // Pabbly Connect relay → /api/leads/pabbly (runs alongside Synamate)
}

enum ProgramLevel {
  SOLO
  GUIDED
  ELITE
  GN_A1
  GN_A2
  GN_B1
  GN_B2
  GN_BUNDLE
  OTHER
}

enum Signal {
  GREEN
  AMBER
  RED
}

// ───────────────────────────── Phase 1 — Finance ─────────────────────────────

enum PaymentType {
  FULL_PAYMENT
  INSTALMENT
}

enum PaymentMethod {
  BANK_TRANSFER_INR
  BANK_TRANSFER_EUR
  PAYPAL
  RAZORPAY
  CASH
  UPI
  CREDIT_CARD
  OTHER
}

enum ExpenseCategory {
  MARKETING
  TOOLS_SOFTWARE
  TEAM_SALARIES
  CONTENT_CREATION
  EVENTS_OFFLINE
  OPERATIONS
  COGS_DIRECT_DELIVERY
  OTHER
}

enum PendingPaymentStatus {
  ACTIVE
  PAID_IN_FULL
  OVERDUE
  DROPPED
}

// Daily income entry (PRD1 §4.2). Admin-only.
model Income {
  id             String        @id @default(cuid())
  date           DateTime      @db.Date
  studentName    String
  // Optional links — how Finance feeds Student LTV (CONTEXT §7). Never required in Phase 1.
  studentId      String?
  student        Student?      @relation(fields: [studentId], references: [id], onDelete: SetNull)
  enrollmentId   String?
  enrollment     Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  amountInrMinor BigInt        @default(0) // paise
  amountEurMinor BigInt        @default(0) // cents
  fxRateUsed     Decimal       @db.Decimal(14, 6) // INR per 1 EUR on entry date
  programLevel   ProgramLevel
  paymentType    PaymentType
  paymentMethod  PaymentMethod
  notes          String?
  source         Source        @default(MANUAL)
  manualOverride Boolean       @default(false)
  externalRef    String? // e.g. Razorpay payment id — de-dupe key for ingest
  enteredById    String?
  enteredBy      User?         @relation("IncomeEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([source, externalRef])
  @@index([date])
  @@index([studentId])
  @@index([programLevel, date])
  @@map("income")
}

// Daily expense entry (PRD1 §4.3). Admin-only.
model Expense {
  id             String          @id @default(cuid())
  date           DateTime        @db.Date
  amountInrMinor BigInt          @default(0)
  amountEurMinor BigInt          @default(0)
  fxRateUsed     Decimal         @db.Decimal(14, 6)
  category       ExpenseCategory
  isCogs         Boolean         @default(false)
  vendor         String
  notes          String?
  source         Source          @default(MANUAL)
  manualOverride Boolean         @default(false)
  externalRef    String?
  enteredById    String?
  enteredBy      User?           @relation("ExpenseEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([source, externalRef])
  @@index([date])
  @@index([isCogs, date])
  @@map("expense")
}

// Pending payments tracker (PRD1 §4.4). "Amount paid so far" is COMPUTED at read time
// by summing Income rows linked to the same student — never stored, never double-entered.
model PendingPayment {
  id               String               @id @default(cuid())
  studentName      String
  studentId        String?
  student          Student?             @relation(fields: [studentId], references: [id], onDelete: SetNull)
  programLevel     ProgramLevel
  totalFeeInrMinor BigInt               @default(0)
  totalFeeEurMinor BigInt               @default(0)
  fxRateUsed       Decimal              @db.Decimal(14, 6)
  nextDueDate      DateTime?            @db.Date
  status           PendingPaymentStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  whatsappMessages WhatsAppMessage[]
  instalments      Instalment[]

  @@index([status, nextDueDate])
  @@map("pending_payment")
}

// ── Structured EMI schedule (spec Module G) ─────────────────────────
// The per-instalment rows the aggregate PendingPayment had no home for: 1 level = 2
// EMIs, 3 levels = 6, each with its own amount, due date, paid date and status.
// PendingPayment.nextDueDate stays as the headline "next due" the dashboards read.
enum InstalmentStatus {
  DUE
  PAID
  OVERDUE
}

model Instalment {
  id               String           @id @default(cuid())
  pendingPaymentId String
  pendingPayment   PendingPayment   @relation(fields: [pendingPaymentId], references: [id], onDelete: Cascade)
  seq              Int // 1-based instalment number
  amountInrMinor   BigInt           @default(0) // paise
  amountEurMinor   BigInt           @default(0) // cents
  fxRateUsed       Decimal          @db.Decimal(14, 6)
  dueDate          DateTime         @db.Date
  paidDate         DateTime?        @db.Date
  status           InstalmentStatus @default(DUE)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([pendingPaymentId, seq])
  @@index([status, dueDate])
  @@map("instalment")
}

// Monthly revenue target for the Pipeline target bar (PRD1 §5.4). Default ₹8,00,000.
model MonthlyTarget {
  id             String   @id @default(cuid())
  month          DateTime @unique @db.Date // first day of month, UTC
  targetInrMinor BigInt   @default(80000000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("monthly_target")
}

// ───────────────────────────── Phase 1 — Pipeline ─────────────────────────────

enum LeadSource {
  INSTAGRAM
  YOUTUBE
  LINKEDIN
  WHATSAPP
  REFERRAL
  SUMMIT
  WORKSHOP
  META_ADS // Meta Lead Ads webhook (Wave-1 capture)
  LANDING_PAGE // FlexiFunnels / website opt-in webhook (Wave-1 capture)
  GHOSTED_BLUEPRINT // Phase 3 attribution tag (PRD3 §3.4) — scoped now, used later
  OTHER
}

enum LeadStage {
  NEW_LEAD
  DISCO_BOOKED
  DISCO_NOT_BOOKED
  DISCO_COMPLETED
  SSS_BOOKED
  SSS_COMPLETED
  PROPOSAL_SENT
  // Synamate pipeline parity (client notes, bucket-1): the workshop branch and the
  // post-offer money trail between "proposal" and "won".
  SENT_TO_WORKSHOP
  WORKSHOP_FOLLOWUP
  OFFER_FOLLOWUP // offer made, didn't buy — follow-up running
  DEPOSIT_FOLLOWUP // agreed, no deposit yet — follow-up running
  DEPOSIT_PAID // confirmed signup with deposit
  WON
  LOST
  NO_SHOW
}

// How a won/deposit deal pays (Synamate "Split Pay / Full Pay").
enum PaymentPlan {
  SPLIT_PAY
  FULL_PAY
}

model Lead {
  id             String        @id @default(cuid())
  name           String
  // Nullable since the Synamate import (16 Jul): 5,886 of 23,432 imported contacts have
  // no phone at all — 5,086 of those have no email either. Every code path that sends
  // (WATI/WhatsApp, the Outreach SOP ladder) MUST null-check before dialling.
  phone          String?
  email          String? // captured from booking form / ad lead (Wave-1)
  city           String?
  industry       String?
  leadSource     LeadSource
  dateIn         DateTime      @db.Date
  stage          LeadStage     @default(NEW_LEAD)
  wonLevel       ProgramLevel? // set when stage → WON; feeds "conversions by level" (PRD1 §5.4)
  paymentPlan    PaymentPlan? // set from DEPOSIT_PAID onward — split pay vs full pay
  notes          String?
  source         Source        @default(MANUAL) // ingest provenance (Synamate / sheet / capture)
  manualOverride Boolean       @default(false)
  externalRef    String?
  utm            Json? // captured UTM params from the ad / landing source (Wave-1)
  // Speed-to-lead (Synamate "Who" + "Speed Ratio"): who owns the lead and when it was
  // first contacted. Speed = contactedAt − createdAt, computed at read time.
  assignedToId   String?
  assignedTo     User?         @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  contactedAt    DateTime?
  enteredById    String?
  enteredBy      User?         @relation("LeadEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  outcomes            DiscoveryOutcome[]
  callLogs            CallLog[]
  stageHistory        LeadStageHistory[]
  students            Student[]
  bookings            BookingRequest[]
  outreachJourney     OutreachJourney?
  whatsappMessages    WhatsAppMessage[]
  agreements          Agreement[]
  // Synamate CRM (Phase 1): the Lead is the Contact record.
  tags                Tag[]                @relation("LeadTags")
  companyId           String?
  company             Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  customFields        Json? // values keyed by CustomFieldDefinition.key (object = CONTACT)
  contactNotes        ContactNote[]
  tasks               ContactTask[]
  opportunities       Opportunity[]
  formSubmissions     FormSubmission[]
  invoices            Invoice[]
  subscriptions       Subscription[]
  messages            Message[]
  workflowEnrollments WorkflowEnrollment[]

  @@unique([source, externalRef])
  @@index([stage])
  @@index([dateIn])
  @@index([leadSource])
  @@index([assignedToId])
  @@index([companyId])
  @@map("lead")
}

// APPEND-ONLY. Written automatically on every stage change — gives Phase 1 its
// "calls booked this month" counts and Phase 3 its "proposals sent this week" pulls.
model LeadStageHistory {
  id          String     @id @default(cuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStage   LeadStage?
  toStage     LeadStage
  changedAt   DateTime   @default(now())
  changedById String?
  changedBy   User?      @relation("StageChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([toStage, changedAt])
  @@map("lead_stage_history")
}

enum CallOutcome {
  QUALIFIED_FOR_SSS
  NOT_QUALIFIED_FOR_SSS
  FOLLOW_UP_NEEDED
  NO_SHOW
  SENT_TO_WORKSHOP
}

// Discovery call outcome (PRD1 §5.3), entered by Asma, linked to a lead.
model DiscoveryOutcome {
  id              String      @id @default(cuid())
  leadId          String
  lead            Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  callDate        DateTime    @db.Date
  outcome         CallOutcome
  highlyQualified Boolean     @default(false) // feeds "Highly qualified rate %" (PRD1 §5.4)
  // BANT qualification (report §3.A) — Asma marks these after the call; drives priority score
  bantBudget      Boolean     @default(false)
  bantAuthority   Boolean     @default(false)
  bantNeed        Boolean     @default(false)
  bantTimeline    Boolean     @default(false)
  sssDate         DateTime?   @db.Date
  notes           String? // key notes to closer
  source          Source      @default(MANUAL)
  manualOverride  Boolean     @default(false)
  externalRef     String?
  enteredById     String?
  enteredBy       User?       @relation("OutcomeEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([source, externalRef])
  @@index([callDate])
  @@map("discovery_outcome")
}

// What actually happened on ONE dial. Distinct from CallOutcome, which grades a completed
// discovery CONVERSATION — this grades the attempt, including the attempts that never connected.
enum CallLogOutcome {
  SPOKE // connected and talked — the only outcome that counts as "client spoken to"
  NO_ANSWER
  BUSY
  CALLBACK // asked to be called back later
  WRONG_NUMBER
  NOT_INTERESTED
}

/// One row per dial attempt: (who × which lead × when × what happened).
///
/// Why this exists: before it, "calls made" came only from DailyLog — a self-reported
/// aggregate the telecaller typed in themselves, with no link to a lead. Nothing recorded
/// that a specific person rang a specific number, so "which of my leads still need a call
/// today?" was unanswerable. This is the append-only fact behind the telecaller desk.
///
/// Append-only by intent: a mis-logged call is corrected with another row, never edited,
/// so the count can't be silently rewritten after the fact (same rule as DailyLog).
model CallLog {
  id        String         @id @default(cuid())
  leadId    String
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // Who dialled. SetNull (not Cascade): deleting a user must never delete the call history
  // that their commission and the team's counts were computed from.
  userId    String?
  user      User?          @relation("CallLoggedBy", fields: [userId], references: [id], onDelete: SetNull)
  calledAt  DateTime       @default(now())
  outcome   CallLogOutcome
  notes     String?
  createdAt DateTime       @default(now())

  // [userId, calledAt] serves "my calls today"; [leadId, calledAt] serves "when was this
  // lead last called" — the two questions the desk asks on every load.
  @@index([userId, calledAt])
  @@index([leadId, calledAt])
  @@index([calledAt])
  @@map("call_log")
}

// ═══════════════ Synamate CRM parity — Phase 1 (SYNAMATE_CLONE_SPEC §5) ═══════════════
// Brings GoHighLevel/Synamate's Contacts + Opportunities into B2. The Lead IS the Contact;
// these models add tags, user-defined custom fields, notes, tasks, company grouping, and a
// proper Opportunity/Pipeline board. The seeded "Sales" pipeline mirrors the LeadStage enum
// and write-throughs to Lead.stage, so existing pipeline/funnel/reminder logic is untouched.

/// Freeform contact tag (Synamate "Tags"). Names stored lowercased+trimmed; implicit m-n to Lead.
model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String? // optional design-token key; falls back to a hashed default in the UI
  createdAt DateTime @default(now())
  leads     Lead[]   @relation("LeadTags")

  @@map("tag")
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  DROPDOWN
  MULTI_SELECT
  CHECKBOX
  PHONE
  EMAIL
  URL
  MONETARY
}

enum CustomFieldObject {
  CONTACT
  OPPORTUNITY
  COMPANY
}

/// User-defined custom field (Synamate "Custom Fields"). Values live as a JSON blob on the
/// owning record (Lead.customFields / Company.customFields), keyed by `key`.
model CustomFieldDefinition {
  id        String            @id @default(cuid())
  object    CustomFieldObject @default(CONTACT)
  name      String
  key       String // slug, unique per object
  fieldType CustomFieldType   @default(TEXT)
  options   Json? // string[] for DROPDOWN / MULTI_SELECT
  position  Int               @default(0)
  createdAt DateTime          @default(now())

  @@unique([object, key])
  @@map("custom_field_definition")
}

/// B2B org grouping (Synamate "Companies"). One company → many contacts.
model Company {
  id           String    @id @default(cuid())
  name         String
  domain       String?
  phone        String?
  email        String?
  address      String?
  city         String?
  country      String?
  ownerId      String?
  owner        User?     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  customFields Json?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  leads Lead[]

  @@index([ownerId])
  @@index([deletedAt])
  @@map("company")
}

/// Contact "Notes" tab. The activity timeline is a read-time merge of these + LeadStageHistory
/// + WhatsAppMessage + DiscoveryOutcome + BookingRequest + completed ContactTasks.
model ContactNote {
  id            String       @id @default(cuid())
  leadId        String
  lead          Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // Optional: a note can also be tagged to one specific deal, so an Opportunity has its own
  // conversation instead of everything being forced onto the parent Lead (BUILD_CHECKLIST.md §3).
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  body          String
  pinned        Boolean      @default(false)
  createdById   String?
  createdBy     User?        @relation("NoteAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([leadId, createdAt])
  @@index([opportunityId, createdAt])
  @@map("contact_note")
}

enum TaskStatus {
  OPEN
  COMPLETED
}

/// Contacts › Tasks (Synamate "Tasks"). May attach to a contact or stand alone.
model ContactTask {
  id           String     @id @default(cuid())
  leadId       String?
  lead         Lead?      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title        String
  body         String?
  dueAt        DateTime?
  status       TaskStatus @default(OPEN)
  completedAt  DateTime?
  assignedToId String?
  assignedTo   User?      @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?      @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status, dueAt])
  @@index([leadId])
  @@index([assignedToId, status])
  @@map("contact_task")
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ABANDONED
}

/// A sales pipeline (Synamate "Pipelines"). Seeded default "Sales" pipeline mirrors LeadStage.
model Pipeline {
  id        String          @id @default(cuid())
  name      String
  position  Int             @default(0)
  isDefault Boolean         @default(false)
  deletedAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  stages    PipelineStage[]
  opps      Opportunity[]

  @@map("pipeline")
}

model PipelineStage {
  id          String        @id @default(cuid())
  pipelineId  String
  pipeline    Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name        String
  position    Int
  // Bridge to the legacy enum: set on the seeded Sales pipeline so a board move write-throughs
  // to Lead.stage (keeping pipeline-metrics / funnel / reminders correct). Null on other pipelines.
  //
  // Known gap (docs/BUILD_CHECKLIST.md §7): this bridge is only populated for the one seeded
  // default pipeline today. A second pipeline's stage moves have no write-through to Lead.stage,
  // so anything reading Lead.stage can silently miss non-default-pipeline activity. Fixing that
  // is a Pipeline Unification Agent decision (extend the bridge everywhere, or make Lead.stage a
  // read-only projection computed from Opportunity) — deliberately not done here: it's a
  // cross-cutting behavior change, not an additive schema column, and touches every place that
  // reads or writes Lead.stage (funnel-metrics, WhatsApp reminders, pipeline dashboard, etc.).
  legacyStage LeadStage?
  // Default deal probability (0-100) for opportunities sitting in this stage, so "pipeline value"
  // can be shown as a weighted forecast rather than a flat sum. Nullable: existing/unset stages
  // fall back to flat-sum behavior until an admin sets one.
  probability Int?
  deletedAt   DateTime?
  opps        Opportunity[]

  @@index([pipelineId, position])
  @@map("pipeline_stage")
}

/// A deal/opportunity on a board (Synamate "Opportunity"). Value stored dual-currency (paise +
/// cents) with the stamped FX rate, exactly like Income/Expense.
model Opportunity {
  id            String            @id @default(cuid())
  leadId        String
  lead          Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  pipelineId    String
  pipeline      Pipeline          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId       String
  stage         PipelineStage     @relation(fields: [stageId], references: [id])
  name          String
  status        OpportunityStatus @default(OPEN)
  valueInrMinor BigInt            @default(0)
  valueEurMinor BigInt            @default(0)
  fxRateUsed    Decimal           @db.Decimal(14, 6)
  source        LeadSource?
  assignedToId  String?
  assignedTo    User?             @relation("OppOwner", fields: [assignedToId], references: [id], onDelete: SetNull)
  position      Int               @default(0) // order within its stage column on the board
  wonAt         DateTime?
  lostReason    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  notes         ContactNote[]

  @@index([pipelineId, stageId, position])
  @@index([leadId])
  @@index([assignedToId, status])
  @@map("opportunity")
}

// ═══════════════ Synamate Sites parity — Phase 2 (SYNAMATE_CLONE_SPEC §Forms/Funnels) ═══════════════
// Native, self-hosted Forms + Funnels/landing pages. A public form/funnel submission funnels through
// the same idempotent lead-intake as the webhooks (source = NATIVE_FORM), so captures land straight
// in the CRM and (optionally) create an Opportunity. Retires the external FlexiFunnels dependency.

/// A reusable form (Synamate "Forms"). `fields` is FormField[]; `settings` is FormSettings JSON
/// (submit text, success message/redirect, tag, lead source, optional opportunity creation).
model Form {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  fields          Json // FormField[]  {key,label,type,required,placeholder?,options?}
  settings        Json // FormSettings
  published       Boolean          @default(false)
  submissionCount Int              @default(0)
  createdById     String?
  createdBy       User?            @relation("FormCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  submissions     FormSubmission[]

  @@map("form")
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  data      Json // raw answers keyed by field key
  utm       Json?
  createdAt DateTime @default(now())

  @@index([formId, createdAt])
  @@index([leadId])
  @@map("form_submission")
}

/// A funnel / multi-step landing site (Synamate "Funnels"/"Websites"). Public at /p/<slug>.
model Funnel {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  published   Boolean      @default(false)
  createdById String?
  createdBy   User?        @relation("FunnelCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  steps       FunnelStep[]

  @@map("funnel")
}

/// One page/step of a funnel. `blocks` is a Block[] JSON (heading/text/image/button/form/video/…).
model FunnelStep {
  id             String  @id @default(cuid())
  funnelId       String
  funnel         Funnel  @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  position       Int
  blocks         Json // Block[]
  seoTitle       String?
  seoDescription String?
  views          Int     @default(0)

  @@unique([funnelId, slug])
  @@index([funnelId, position])
  @@map("funnel_step")
}

// ═══════════════ Synamate Payments parity — Phase 3 (invoicing, no processor yet) ═══════════════
// Invoices + estimates (kind), reusable Products, manual Payments (Transactions), and Subscriptions.
// Money is dual INR (paise, primary) + EUR (cents) with a stamped fxRate, like Income/Expense. No
// payment processor is wired yet — status is advanced manually; `publicToken` powers /i/<token>.
// A `provider` + `externalId` seam is left on payments so Razorpay/Stripe can drop in later.

enum ProductInterval {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

model Product {
  id            String          @id @default(cuid())
  name          String
  description   String?
  priceInrMinor BigInt          @default(0)
  priceEurMinor BigInt          @default(0)
  fxRateUsed    Decimal?        @db.Decimal(14, 6) // INR per 1 EUR when the EUR price was last set
  interval      ProductInterval @default(ONE_TIME)
  active        Boolean         @default(true)
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  subscriptions Subscription[]

  @@map("product")
}

enum InvoiceKind {
  INVOICE
  ESTIMATE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  VOID
  ACCEPTED // estimates
  DECLINED // estimates
}

model Invoice {
  id               String            @id @default(cuid())
  kind             InvoiceKind       @default(INVOICE)
  number           String            @unique // INV-0001 / EST-0001
  status           InvoiceStatus     @default(DRAFT)
  leadId           String?
  lead             Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerName     String
  customerEmail    String?
  customerPhone    String?
  issueDate        DateTime          @db.Date
  dueDate          DateTime?         @db.Date
  subtotalInrMinor BigInt            @default(0)
  discountInrMinor BigInt            @default(0)
  taxPercent       Decimal           @default(0) @db.Decimal(6, 3)
  taxInrMinor      BigInt            @default(0)
  totalInrMinor    BigInt            @default(0)
  totalEurMinor    BigInt            @default(0)
  fxRateUsed       Decimal           @db.Decimal(14, 6)
  notes            String?
  publicToken      String            @unique @default(cuid())
  sentAt           DateTime?
  paidAt           DateTime?
  createdById      String?
  createdBy        User?             @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  items            InvoiceLineItem[]
  payments         InvoicePayment[]

  @@index([status])
  @@index([kind, createdAt])
  @@index([leadId])
  @@map("invoice")
}

model InvoiceLineItem {
  id                String  @id @default(cuid())
  invoiceId         String
  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description       String
  quantity          Int     @default(1)
  unitPriceInrMinor BigInt  @default(0)
  position          Int     @default(0)

  @@index([invoiceId])
  @@map("invoice_line_item")
}

model InvoicePayment {
  id             String   @id @default(cuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountInrMinor BigInt
  method         String // cash / upi / bank / razorpay / stripe (free text until a processor is wired)
  reference      String?
  provider       String? // future: "razorpay" | "stripe"
  externalId     String? // future: processor payment id
  paidAt         DateTime @default(now())
  recordedById   String?
  recordedBy     User?    @relation("InvoicePaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([recordedById])
  @@map("invoice_payment")
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Subscription {
  id              String             @id @default(cuid())
  leadId          String?
  lead            Lead?              @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerName    String
  productId       String?
  product         Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  amountInrMinor  BigInt             @default(0)
  amountEurMinor  BigInt             @default(0)
  fxRateUsed      Decimal?           @db.Decimal(14, 6) // INR per 1 EUR when the EUR amount was last set
  interval        ProductInterval    @default(MONTHLY)
  status          SubscriptionStatus @default(ACTIVE)
  nextBillingDate DateTime?          @db.Date
  startedAt       DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([leadId])
  @@map("subscription")
}

// ═══════════════ Synamate Conversations parity — Phase 4 (Email + SMS + templates) ═══════════════
// Adds Email + SMS channels beside the existing WhatsApp/WATI log, reusable message templates, and
// a unified inbox (read-time merge of Message + WhatsAppMessage per contact). Providers (Resend for
// email, Twilio for SMS) are fetch-based and OFF by default — with keys unset a send writes a
// SKIPPED row and nothing leaves the app, exactly like the WATI seam.

enum MessageChannel {
  EMAIL
  SMS
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  SKIPPED // provider off / opted out — logged, not sent
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model Message {
  id           String           @id @default(cuid())
  channel      MessageChannel
  direction    MessageDirection @default(OUTBOUND)
  status       MessageStatus    @default(QUEUED)
  leadId       String?
  lead         Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  toAddress    String // email address or phone number
  fromAddress  String?
  subject      String? // email only
  body         String
  provider     String? // "resend" | "twilio"
  externalId   String?
  error        String?
  sentById     String?
  sentBy       User?            @relation("MessageSentBy", fields: [sentById], references: [id], onDelete: SetNull)
  // Conversations inbox read-state + assignment (docs/BUILD_CHECKLIST.md §8). Inbound messages
  // default unread; outbound ones are meaningless to mark unread but the field stays uniform.
  read         Boolean          @default(false)
  assignedToId String?
  assignedTo   User?            @relation("MessageAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())

  @@index([leadId, createdAt])
  @@index([channel, createdAt])
  @@index([direction, read])
  @@index([assignedToId])
  @@map("message")
}

model MessageTemplate {
  id        String         @id @default(cuid())
  channel   MessageChannel
  name      String
  subject   String? // email only
  body      String // supports {{name}} / {{first_name}} tokens
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("message_template")
}

// ═══════════════ Synamate Automation parity — Phase 5 (workflow engine) ═══════════════
// A trigger (form submit / tag added / stage change / contact created / invoice paid / booking)
// enrolls a contact, then runs a linear list of actions (send email/SMS, add/remove tag, move stage,
// create task, wait). WAIT actions pause the enrollment; a cron (/api/cron/workflows, CRON_SECRET)
// resumes due ones — the SAME external-cron seam the WhatsApp reminders use. Loop-guarded: an active
// enrollment is never re-created for the same (workflow, contact), and actions never re-emit triggers.

enum WorkflowStatus {
  DRAFT
  PUBLISHED
}

enum TriggerType {
  FORM_SUBMITTED
  TAG_ADDED
  STAGE_CHANGED
  CONTACT_CREATED
  INVOICE_PAID
  BOOKING_CREATED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
}

/// Synamate parity: workflows are grouped into folders ("Calendar Booking Automations",
/// "Pipeline Automations", …). Flat (no nesting) — the reference only ever shows one level.
model WorkflowFolder {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  workflows Workflow[]

  @@map("workflow_folder")
}

model Workflow {
  id            String               @id @default(cuid())
  name          String
  status        WorkflowStatus       @default(DRAFT)
  triggerType   TriggerType
  triggerConfig Json? // { formId? | tag? | stage? }
  actions       Json // WorkflowAction[]
  totalEnrolled Int                  @default(0)
  /// null = the root ("Home") folder in the UI. SetNull so deleting a folder never
  /// takes its workflows with it — they fall back to root.
  folderId      String?
  folder        WorkflowFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  /// Soft delete: set = in the "Deleted" tab, excluded from every live read and from
  /// emitTrigger's enrollment scan. Restorable. Hard delete is admin-only + explicit.
  deletedAt     DateTime?
  createdById   String?
  createdBy     User?                @relation("WorkflowCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  enrollments   WorkflowEnrollment[]

  // emitTrigger filters on (status, triggerType, deletedAt) — keep all three together.
  @@index([status, triggerType, deletedAt])
  @@index([folderId])
  @@index([deletedAt])
  @@map("workflow")
}

model WorkflowEnrollment {
  id          String           @id @default(cuid())
  workflowId  String
  workflow    Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(ACTIVE)
  currentStep Int              @default(0)
  nextRunAt   DateTime? // null = ready now; set to a future time by a WAIT action
  context     Json?
  lastError   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, nextRunAt])
  @@index([workflowId, leadId])
  @@map("workflow_enrollment")
}

// ─────────────────── Wave-1 — Booking + Lead capture (Synamate in-sourcing) ───────────────────
// Replaces Synamate's two functions in-house: (1) a public qualification booking page that
// scores BANT and books a slot, (2) a lead inbox fed by our own webhooks (Meta / FlexiFunnels)
// plus manual entry. No automated messaging here — that is Wave-2, gated on Ameen's sign-off.

enum SlotStatus {
  OPEN
  BOOKED
  BLOCKED
}

// Weighted-BANT recommendation (avg of the four 0–5 dimension scores).
enum BantVerdict {
  CONFIRM // avg > 3 — confirm the call
  DOUBT // avg 2–3 — go ahead, but doubt they'll convert
  CANCEL // avg < 2 — cancel / don't book the call
}

enum BookingStatus {
  BOOKED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// Bookable discovery-call slots (replaces Synamate's calendar). Admin generates availability;
// the public booking page shows OPEN future slots. startsAt is a UTC instant, shown in IST + CET.
model AppointmentSlot {
  id           String          @id @default(cuid())
  startsAt     DateTime // UTC instant
  durationMins Int             @default(30)
  status       SlotStatus      @default(OPEN)
  assignedToId String?
  assignedTo   User?           @relation("SlotAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  booking      BookingRequest?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status, startsAt])
  @@map("appointment_slot")
}

/// SSS (Success Strategy Session) slot — the founder-run sales/closing call calendar. Distinct
/// from AppointmentSlot (the public discovery booking): an SSS slot is booked by linking an
/// existing OutreachJourney, not a fresh BANT intake. Reuses SlotStatus (OPEN/BOOKED/BLOCKED).
///
/// Block/unblock and auto-reschedule (server/sss-slots.ts) mirror the discovery
/// booking-automation engine: blocking a BOOKED slot moves its journey to the next OPEN slot for
/// the same owner and resets the SSS confirmation. journey.sssAt is kept in sync with startsAt.
model SssSlot {
  id           String     @id @default(cuid())
  startsAt     DateTime // UTC instant
  durationMins Int        @default(45)
  status       SlotStatus @default(OPEN)
  // Who runs this SSS (defaults to the configured SSS owner). Per-slot so a reschedule keeps the
  // same closer and blocking one owner's day leaves another owner's slots untouched.
  ownerId      String?
  owner        User?      @relation("SssSlotOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  // The prospect's journey booked into this slot (null unless BOOKED). One journey → at most one
  // SSS slot.
  journeyId    String?          @unique
  journey      OutreachJourney? @relation("SssSlotJourney", fields: [journeyId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status, startsAt])
  @@index([ownerId, startsAt])
  @@map("sss_slot")
}

// Public qualification intake (parity with Synamate's "Appointment booking" export).
// BANT is computed from the answers at submit time (src/lib/bant.ts) and mirrored to the
// linked Lead so the pipeline's "Call these first" scoring can reuse it.
model BookingRequest {
  id     String           @id @default(cuid())
  slotId String?          @unique
  slot   AppointmentSlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  leadId String?
  lead   Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Contact
  name     String
  email    String
  phone    String
  whatsapp String?
  city     String?

  // Qualification answers (free-text / select values, stored verbatim as Synamate did)
  currentJobTitle        String?
  prospectIndustry       String?
  linkedInProfile        String?
  highestEducation       String?
  yearsExperience        String?
  whyGermany             String?
  participateWorkshop    Boolean @default(false)
  reasonForCall          String?
  alreadyApplied         String?
  whenStartGermany       String?
  germanVisa             String?
  germanLevel            String?
  willingnessLearnGerman String?
  currentIncome          String?
  readyToInvest          String?
  decisionMaking         String?
  commitment             String?
  howKnowUs              String?

  // BANT — derived on submit; bantScore is 0–4 (count of the four dimensions met).
  // Weighted layer (client notes): every answer carries a 0–5 score; bantAvg is the
  // mean of the four dimension scores and bantVerdict applies Ameen's thresholds
  // (>3 confirm · 2–3 doubt · <2 cancel). Recommendation only — no automated action.
  bantBudget    Boolean      @default(false)
  bantAuthority Boolean      @default(false)
  bantNeed      Boolean      @default(false)
  bantTimeline  Boolean      @default(false)
  bantScore     Int          @default(0)
  bantAvg       Float?
  bantVerdict   BantVerdict?

  // Confirmation loop (Module E). A booked call must be confirmed before it happens; if the
  // prospect never confirms, the auto-cancel engine (booking-automation.ts) releases the slot and
  // promotes the next same-caller/same-day call into it. `confirmSentAt` records when the
  // confirm-request went out (so the engine asks once, then cancels if unanswered); `confirmedAt`
  // is set by a WhatsApp "yes" (wati/webhook) or a manual "Mark confirmed" from the Bookings table.
  confirmSentAt DateTime?
  confirmedAt   DateTime?

  status      BookingStatus @default(BOOKED)
  source      Source        @default(BOOKING_FORM)
  utm         Json?
  externalRef String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  whatsappMessages WhatsAppMessage[]
  outreachJourney  OutreachJourney?

  @@index([status, createdAt])
  @@index([bantScore])
  // Step 10 (booking cross-check) matches a lead to a booking by email. Postgres can only use
  // an index for that if the query's lower(email) matches an expression index of the same shape.
  @@index([email])
  @@map("booking_request")
}

// ───────────────────────────── Phase 2 — People ─────────────────────────────

enum TeamStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
}

// Which daily-log form a person gets (PRD2 §3.3) — by function, not hardcoded name.
enum DailyLogVariant {
  DISCOVERY_SPECIALIST // Asma: calls completed, HQ calls, follow-ups, proposals, no-shows
  APPOINTMENT_SETTER // Nilofer: leads contacted, appointments set, follow-ups, pipeline adds
  DELIVERY_COACH // Karthick: sessions, check-ins, assignments, at-risk flags
}

// Who wrote a DailyLog row. The Telecaller Pay board sums these numbers into the calls a
// bonus/commission is judged on, so "a person said this" and "the EOD job derived this from
// activity" must never look the same.
//
// HUMAN    — submitted by the member. One-shot and immutable (PRD2 §3.3).
// EOD_AUTO — the member never logged, so the EOD job wrote what activity it could derive.
//            Auto-capture cannot see every field (followUpMessagesSent has no event source),
//            so these rows are INCOMPLETE by construction and read low on the pay board.
//            That is why, unlike a HUMAN row, they stay amendable by their owner for a
//            short window — the member fills in the rest and the row flips to HUMAN.
enum DailyLogSource {
  HUMAN
  EOD_AUTO
}

model TeamProfile {
  id                  String          @id @default(cuid())
  userId              String?         @unique
  user                User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName            String
  roleTitle           String // e.g. Discovery Call Specialist
  dashboardRole       Role            @default(USER)
  email               String
  phone               String?
  dateJoined          DateTime?       @db.Date
  keyResponsibilities String?
  status              TeamStatus      @default(ACTIVE)
  logVariant          DailyLogVariant
  orderIndex          Int             @default(0) // org-chart card order (Admin can rearrange)
  // First-call assignment rules (client notes): target share of incoming leads
  // (Nilofer 80 / Asma 20) and Saturday availability (Asma doesn't work Saturdays).
  // Drives the intake auto-assign suggestion; manual reassignment always overrides.
  firstCallSharePct   Int             @default(0) // 0 = not in the first-call rotation
  worksSaturdays      Boolean         @default(true)
  // How many calls this person is expected to make on a working day. Admin-set (dynamic),
  // 0 = no target, which hides the target UI rather than showing "0 / 0".
  // Deliberately NOT a Goal: GoalPeriod has no DAY, and a daily bar is a working-day
  // notion (Saturdays follow worksSaturdays) that the monthly Goal engine doesn't model.
  dailyCallTarget     Int             @default(0)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  okrs              OKR[]
  telecallerPayouts TelecallerPayout[]
  goals             Goal[]
  rewardGrants      RewardGrant[]

  @@map("team_profile")
}

// Max 3 per person per month — enforced at the service layer (PRD2 §3.2).
model OKR {
  id                  String      @id @default(cuid())
  teamProfileId       String
  teamProfile         TeamProfile @relation(fields: [teamProfileId], references: [id], onDelete: Cascade)
  month               DateTime    @db.Date // first day of month
  title               String
  targetValue         String // "80%", "50 calls" — free text per PRD
  targetNumeric       Decimal?    @db.Decimal(14, 2) // parsed when numeric → auto completion %
  currentProgress     String?
  currentNumeric      Decimal?    @db.Decimal(14, 2)
  manualCompletionPct Int? // Admin sets when target is text (PRD2 §3.2)
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([teamProfileId, month])
  @@map("okr")
}

// APPEND-ONLY (PRD2 §6): one per user per day; corrections are notes, never edits.
model DailyLog {
  id      String          @id @default(cuid())
  userId  String
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  date    DateTime        @db.Date
  variant DailyLogVariant

  // DISCOVERY_SPECIALIST
  discoveryCallsCompleted Int?
  highlyQualifiedCalls    Int?
  followUpsDone           Int?
  proposalsSent           Int?
  noShows                 Int?

  // APPOINTMENT_SETTER
  newLeadsContacted    Int?
  appointmentsSet      Int?
  followUpMessagesSent Int?
  leadsAddedToPipeline Int?

  // DELIVERY_COACH
  sessionsDelivered     Int?
  studentsCheckedInOn   Int?
  assignmentsReviewed   Int?
  studentsFlaggedAtRisk Int?

  // HUMAN unless the EOD job wrote it. Defaulted, so every pre-existing row is correctly
  // HUMAN — before this field existed, a row could only come from the submit form.
  source DailyLogSource @default(HUMAN)

  notes          String? // notes / blockers
  correctionNote String? // Admin may append a correction — original stays intact
  // Which numeric fields were auto-filled from real activity at submit time (report §3.A).
  // A JSON array of field keys — lets the timeline badge historical entries as auto-captured,
  // not just today's (today's is recomputed live; history needs this record).
  autoCapturedKeys Json?
  createdAt        DateTime @default(now())

  @@unique([userId, date]) // one log per person per day (PRD2 §3.3)
  @@index([date])
  @@map("daily_log")
}

// Whether an assigned reward has actually been paid out yet.
enum PayoutStatus {
  PENDING
  PAID
}

// Telecaller rewards: Admin (Ameen) assigns a BONUS and/or COMMISSION to a
// telecaller (a USER-role TeamProfile — appointment setters / discovery specialists)
// for a given month, with a free-text reason ("based on the calls or any other
// criteria"). Amounts are entered manually. Dual-currency like all money in the
// app: INR + EUR minor units, FX stamped at entry so history never re-prices.
model TelecallerPayout {
  id            String       @id @default(cuid())
  teamProfileId String
  teamProfile   TeamProfile  @relation(fields: [teamProfileId], references: [id], onDelete: Cascade)
  month         DateTime     @db.Date // first day of the month this reward is for
  bonusInrMinor BigInt       @default(0) // paise
  bonusEurMinor BigInt       @default(0) // cents
  commInrMinor  BigInt       @default(0) // commission, paise
  commEurMinor  BigInt       @default(0) // commission, cents
  fxRateUsed    Decimal      @db.Decimal(14, 6) // INR per 1 EUR at entry
  reason        String // the criteria: calls hit, targets, QA, spot bonus…
  status        PayoutStatus @default(PENDING)
  enteredById   String?
  enteredBy     User?        @relation("TelecallerPayoutEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([teamProfileId, month])
  @@index([month])
  @@map("telecaller_payout")
}

// ───────────────────────────── Phase 2 — Students ─────────────────────────────

enum StudentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PAUSED
}

enum ProgramDuration {
  DAYS_90 // Guided
  DAYS_120 // Elite
  LIFETIME // Solo — no end date, no tracker
}

enum Milestone {
  ONBOARDING
  RESUME_BUILD
  LINKEDIN_OPTIMISATION
  APPLICATIONS
  INTERVIEWS
  OFFER_RECEIVED
  COMPLETED
}

enum TaskCompletion {
  YES
  NO
  PENDING
}

// ONE person = ONE Student record; upgrades create additional Enrollments (CONTEXT §7).
// LTV = sum of linked Income across all enrollments — computed, never stored.
model Student {
  id            String      @id @default(cuid())
  fullName      String
  email         String?
  phone         String?
  industry      String?
  targetRole    String? // target country role in Germany
  leadSource    LeadSource? // GHOSTED_BLUEPRINT here drives Phase 3 attribution
  leadId        String?
  lead          Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  // Optional portal login (Role.STUDENT). One student ↔ one user; deleting the
  // user account never touches the student record.
  userId        String?     @unique
  user          User?       @relation("StudentAccount", fields: [userId], references: [id], onDelete: SetNull)
  internalNotes String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  enrollments        Enrollment[]
  incomes            Income[]
  pendingPayments    PendingPayment[]
  satisfactionScores SatisfactionScore[]
  gnMemberships      GnBatchMember[]
  whatsappMessages   WhatsAppMessage[]
  agreements         Agreement[]

  @@index([fullName])
  @@map("student")
}

model Enrollment {
  id              String          @id @default(cuid())
  studentId       String
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  programLevel    ProgramLevel // SOLO / GUIDED / ELITE only for B2 (service-validated)
  enrollmentDate  DateTime        @db.Date
  duration        ProgramDuration
  programEndDate  DateTime?       @db.Date // enrollment + 90/120 days; null for LIFETIME
  assignedCoach   String? // currently Karthick
  // L3 closer who ran the sales/SSS call — the third leg of the commission split
  // (setter + discovery are inferred from the Lead; the closer had no home before).
  closerId        String?
  closer          User?           @relation("EnrollmentCloser", fields: [closerId], references: [id], onDelete: SetNull)
  status          StudentStatus   @default(ACTIVE)
  statusChangedAt DateTime        @default(now()) // powers "completed/dropped this month"

  // 90/120-day tracker (PRD2 §4.3) — Guided/Elite only
  lastSessionDate        DateTime?       @db.Date
  totalSessionsCompleted Int             @default(0)
  totalSessionsPlanned   Int?
  lastTaskAssigned       String?
  lastTaskCompleted      TaskCompletion?
  applicationsSubmitted  Int             @default(0)
  interviewsReceived     Int             @default(0)
  currentMilestone       Milestone       @default(ONBOARDING)
  signalColour           Signal? // manual G/A/R, set by Admin/Head
  signalNotes            String?
  nextCheckInDate        DateTime?       @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  incomes         Income[]
  milestoneLogs   MilestoneLog[]
  signalChanges   SignalChangeLog[]
  sprintWeeks     SprintWeek[]
  jobApplications JobApplication[]

  @@index([studentId])
  @@index([status, programLevel])
  @@index([signalColour])
  @@index([closerId])
  @@map("enrollment")
}

// ── Per-application placement tracking (spec Module I) ──────────────
// Richer than the aggregate counts on Enrollment (applicationsSubmitted /
// interviewsReceived), which stay as the tracker's headline numbers. One row per
// real application, moving applied → interview → selected/rejected.
enum JobApplicationStatus {
  APPLIED
  INTERVIEW
  SELECTED
  REJECTED
}

model JobApplication {
  id           String               @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  company      String
  role         String
  jobUrl       String?
  location     String?
  status       JobApplicationStatus @default(APPLIED)
  appliedAt    DateTime             @db.Date
  statusAt     DateTime             @default(now()) // when it last changed status
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([enrollmentId, status])
  @@index([status, statusAt])
  @@map("job_application")
}

// ── Sprint tracker (client notes): week-wise targets after course completion ──
// Guided = 90 days (13 weeks) · Elite = 120 days (17 weeks). Coach sets the target,
// the weekend check-in records the actual; ACHIEVED = "no disturbance", MISSED feeds
// the at-risk radar. The WhatsApp nudge on a miss is Wave-2 (gated) — here it's data.

enum SprintStatus {
  PENDING // week not reviewed yet
  ACHIEVED // target met — no disturbance
  MISSED // target missed — ask why / take action
}

model SprintWeek {
  id            String       @id @default(cuid())
  enrollmentId  String
  enrollment    Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  weekIndex     Int // 1-based
  weekStart     DateTime     @db.Date
  weekEnd       DateTime     @db.Date // inclusive last day (the check-in weekend)
  target        String? // e.g. "15 applications, 2 networking calls"
  targetNumeric Decimal?     @db.Decimal(14, 2) // parsed when numeric → auto achieved/missed
  actual        String? // what actually happened (student check-in or coach entry)
  actualNumeric Decimal?     @db.Decimal(14, 2)
  status        SprintStatus @default(PENDING)
  note          String? // why missed / coach comment
  enteredById   String?
  enteredBy     User?        @relation("SprintEnteredBy", fields: [enteredById], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([enrollmentId, weekIndex])
  @@index([status, weekEnd])
  @@map("sprint_week")
}

// APPEND-ONLY milestone history (PRD2 §4.4) — cannot be deleted by anyone, incl. Admin.
model MilestoneLog {
  id                String     @id @default(cuid())
  enrollmentId      String
  enrollment        Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  date              DateTime   @default(now())
  updatedById       String?
  updatedBy         User?      @relation("MilestoneUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  previousMilestone Milestone?
  newMilestone      Milestone
  note              String?

  @@index([enrollmentId])
  @@map("milestone_log")
}

// APPEND-ONLY signal-colour audit (PRD2 §6: every change logged with date + user).
model SignalChangeLog {
  id             String     @id @default(cuid())
  enrollmentId   String
  enrollment     Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  date           DateTime   @default(now())
  changedById    String?
  changedBy      User?      @relation("SignalChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  previousSignal Signal?
  newSignal      Signal? // null = signal cleared back to "not set" (still audited)
  note           String?

  @@index([enrollmentId])
  @@map("signal_change_log")
}

enum OutcomeAchieved {
  JOB_OFFER_RECEIVED
  INTERVIEWS_ONLY
  APPLICATIONS_STAGE
  NO_OUTCOME_YET
}

model SatisfactionScore {
  id                  String          @id @default(cuid())
  studentId           String
  student             Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date                DateTime        @db.Date
  satisfactionScore   Int // 1–10
  npsScore            Int // 0–10
  testimonialReceived Boolean         @default(false)
  outcomeAchieved     OutcomeAchieved @default(NO_OUTCOME_YET)
  notes               String?
  createdAt           DateTime        @default(now())

  @@index([studentId])
  @@map("satisfaction_score")
}

// ───────────────────────────── Phase 3 — Conversion Funnel ─────────────────────────────

// Weekly snapshot (PRD3 §3.2). Awareness/GB downloads are always manual; leads/calls/
// proposals/enrollments are pre-filled from Phase 1+2 native queries, Admin can override.
model WeeklyFunnelSnapshot {
  id                String   @id @default(cuid())
  weekStart         DateTime @unique @db.Date // Monday
  awarenessReach    Int      @default(0)
  leadsCaptured     Int      @default(0)
  callsCompleted    Int      @default(0)
  proposalsSent     Int      @default(0)
  enrollmentsSolo   Int      @default(0)
  enrollmentsGuided Int      @default(0)
  enrollmentsElite  Int      @default(0)
  ghostedDownloads  Int      @default(0)
  workshopAttendees Int      @default(0)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("weekly_funnel_snapshot")
}

// ───────────────────────────── Phase 3 — Cash Health ─────────────────────────────

// Weekly bank-balance log (PRD3 §4.1). Kept as history for the 12-week line chart.
model CashPosition {
  id                      String   @id @default(cuid())
  date                    DateTime @unique @db.Date // should be a Monday
  bankBalanceInrMinor     BigInt   @default(0)
  personalSavingsInrMinor BigInt? // optional, planning only — excluded from runway
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("cash_position")
}

enum PayableFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME
}

enum PayableStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

model Payable {
  id             String           @id @default(cuid())
  name           String
  category       ExpenseCategory
  amountInrMinor BigInt           @default(0)
  frequency      PayableFrequency @default(MONTHLY)
  nextDueDate    DateTime?        @db.Date
  isCogs         Boolean          @default(false)
  status         PayableStatus    @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, nextDueDate])
  @@map("payable")
}

// ───────────────────────────── Phase 4 — German Note ─────────────────────────────
// LMS-lite for the German language program: Admin creates batches (A1..B2 cohorts)
// and assigns a TUTOR + Students. Classes are recorded by fathom.ai; the tutor
// pastes the Fathom share link (YouTube/Vimeo/Drive also accepted) into their
// batch. Students keep LIFETIME access to their batch's recordings — batch
// membership never expires; archiving a batch only closes its discussion.
// Community = Skool-style feed: GnPost.batchId null → global, set → batch.

enum GnBatchStatus {
  ACTIVE
  ARCHIVED
}

enum GnVideoProvider {
  FATHOM // primary: classes are recorded by fathom.ai, tutor pastes the share link
  YOUTUBE
  VIMEO
  GDRIVE
}

model GnBatch {
  id        String        @id @default(cuid())
  name      String // "A1 Evening — July 2026"
  level     ProgramLevel // GN_A1..GN_B2 only (service-validated, like B2_LEVELS)
  tutorId   String?
  tutor     User?         @relation("GnBatchTutor", fields: [tutorId], references: [id], onDelete: SetNull)
  status         GnBatchStatus @default(ACTIVE)
  targetStrength Int           @default(8) // target class size (spec: ~8 per batch)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  members    GnBatchMember[]
  recordings GnRecording[]
  posts      GnPost[]
  modules    GnModule[]
  events     GnEvent[]

  @@index([status])
  @@index([tutorId])
  @@map("gn_batch")
}

// Classroom curriculum: an ordered section grouping a batch's lessons
// (recordings). Recordings with moduleId null fall into the default section.
model GnModule {
  id         String   @id @default(cuid())
  batchId    String
  batch      GnBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title      String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  recordings GnRecording[]

  @@index([batchId, orderIndex])
  @@map("gn_module")
}

// The kind of session a calendar event represents (spec: kickoff / coaching /
// LinkedIn / Q&A / open-market strategy). LIVE_CLASS is the German-Note default.
enum GnEventType {
  KICKOFF
  COACHING
  LINKEDIN
  QA
  OPEN_MARKET
  LIVE_CLASS
  OTHER
}

// Scheduled live classes (calendar). Students see upcoming + a join link;
// the recording gets posted afterwards as a GnRecording.
model GnEvent {
  id           String      @id @default(cuid())
  batchId      String
  batch        GnBatch     @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title        String
  type         GnEventType @default(LIVE_CLASS)
  startsAt     DateTime
  durationMins Int?
  joinUrl      String?
  notes        String?
  createdById  String?
  createdBy    User?    @relation("GnEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([batchId, startsAt])
  @@map("gn_event")
}

// Members reference Student (not User) so Admin can add people before any
// portal login exists; the existing createStudentLogin flow links a User later.
model GnBatchMember {
  id        String   @id @default(cuid())
  batchId   String
  batch     GnBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([batchId, studentId])
  @@index([studentId])
  @@map("gn_batch_member")
}

model GnRecording {
  id         String          @id @default(cuid())
  batchId    String
  batch      GnBatch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  moduleId   String? // classroom section; null = default "Class recordings"
  module     GnModule?       @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  title      String
  classDate  DateTime        @db.Date
  videoUrl   String // original pasted URL ("open original" link)
  provider   GnVideoProvider
  embedUrl   String // derived iframe src, stored at write time
  notes      String?
  postedById String?
  postedBy   User?           @relation("GnRecordingPostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  watches GnRecordingWatch[]

  @@index([batchId, classDate])
  @@index([moduleId])
  @@map("gn_recording")
}

// Per-viewer "watched" state → the batch progress bar + completion checkmarks.
// Recordings are lifetime, so this is progress, not access control.
model GnRecordingWatch {
  id          String      @id @default(cuid())
  recordingId String
  recording   GnRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation("GnRecordingWatchUser", fields: [userId], references: [id], onDelete: Cascade)
  watchedAt   DateTime    @default(now())

  @@unique([recordingId, userId])
  @@index([userId])
  @@map("gn_recording_watch")
}

// Skool-style post categories — power the filter chips on the feed.
enum GnPostCategory {
  GENERAL
  ANNOUNCEMENT
  QUESTION
  WIN
}

// Authors are SetNull so revoking a login never destroys community content —
// UI renders "Former member" when author is null. Feed order is Skool-like:
// pinned first, then by latest activity (a new comment bumps the post).
model GnPost {
  id               String         @id @default(cuid())
  batchId          String? // null = global GN community feed; set = batch discussion
  batch            GnBatch?       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  authorId         String?
  author           User?          @relation("GnPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  title            String? // Skool posts lead with a bold title; optional for quick questions
  category         GnPostCategory @default(GENERAL)
  pinned           Boolean        @default(false) // Admin (global) / batch tutor (batch) pin posts to the top
  body             String
  imageUrl         String? // optional single image, stored as a resized data URL (like avatars)
  mentionedUserIds String[] // @mention targets, resolved server-side → notifications
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  comments GnComment[]
  likes    GnLike[]

  @@index([batchId, createdAt])
  @@map("gn_post")
}

model GnComment {
  id               String   @id @default(cuid())
  postId           String
  post             GnPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId         String?
  author           User?    @relation("GnCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body             String
  mentionedUserIds String[]
  createdAt        DateTime @default(now())

  likes GnCommentLike[]

  @@index([postId, createdAt])
  @@map("gn_comment")
}

model GnLike {
  id        String   @id @default(cuid())
  postId    String
  post      GnPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("GnLikeUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("gn_like")
}

// Comment likes — separate table from post likes; both feed community points/levels.
model GnCommentLike {
  id        String    @id @default(cuid())
  commentId String
  comment   GnComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation("GnCommentLikeUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([commentId, userId])
  @@map("gn_comment_like")
}

// ── German Note — Workshops → conversions by level ─────────────
// A workshop is a paid-ad intake (e.g. "May 2026"): people attend a free
// German taster, and a share convert into a level course (A1 / A2 / B1 or a
// bundle). Reverse-engineered from the founders' monthly workshop workbooks —
// the conversions table, the ad-performance block and the P&L rollup.
// Admin-only, like the rest of German Note management. Money = INR paise.

enum GnWorkshopStatus {
  ACTIVE
  ARCHIVED
}

// The "Product Chosen" dropdown: single levels + the discounted bundles.
enum GnWorkshopProduct {
  A1
  A2
  B1
  A1_A2
  A2_B1
  A1_A2_B1
}

enum GnWorkshopDayType {
  WEEKDAY
  WEEKEND
}

// A confirmed sale still awaiting start/settlement shows as ON_HOLD in the sheet.
enum GnConversionStatus {
  CONFIRMED
  ON_HOLD
}

// How the conversion reached us — drives ad-spend attribution. AD conversions
// split the workshop's ad spend between them; ORGANIC ones carry no ad cost.
enum GnWorkshopSource {
  AD
  ORGANIC
}

model GnWorkshop {
  id        String           @id @default(cuid())
  name      String // "May 2026"
  month     DateTime         @db.Date // first of the intake month — drives ordering
  status    GnWorkshopStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  conversions GnWorkshopConversion[]
  adSets      GnWorkshopAdSet[]

  @@index([status])
  @@map("gn_workshop")
}

// One ad-set's performance for a workshop (May ran two, March one). Drives the
// ad-performance panel: attendance %, CTR, CPC, conversion % and ROAS.
model GnWorkshopAdSet {
  id              String     @id @default(cuid())
  workshopId      String
  workshop        GnWorkshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  label           String? // "Set A", optional
  adSpendInrMinor BigInt     @default(0) // paise
  reach           Int        @default(0)
  linkClicks      Int        @default(0)
  attended        Int        @default(0) // registrations / attendees on the taster
  conversions     Int        @default(0) // deals closed attributed to this set
  orderIndex      Int        @default(0)
  createdAt       DateTime   @default(now())

  @@index([workshopId])
  @@map("gn_workshop_adset")
}

// One client who converted from the workshop into a level course.
// COGS = books + tutor; Gross = final − COGS; Total Exp = COGS + ads + referral;
// Net = final − Total Exp; ROAS = final ÷ ads. (Verified against the sheet rollup.)
model GnWorkshopConversion {
  id                        String             @id @default(cuid())
  workshopId                String
  workshop                  GnWorkshop         @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  fullName                  String
  email                     String?
  phone                     String?
  address                   String?
  product                   GnWorkshopProduct
  dayType                   GnWorkshopDayType  @default(WEEKDAY)
  // per-level batch assignment (label + time), free-text like the sheet ("B26", "7:00 AM")
  batchA1                   String?
  timeA1                    String?
  batchA2                   String?
  timeA2                    String?
  batchB1                   String?
  timeB1                    String?
  source                    GnWorkshopSource   @default(AD) // AD = from the workshop ad campaign; ORGANIC = referral / carry-over / free
  status                    GnConversionStatus @default(CONFIRMED)
  isFreeSeat                Boolean            @default(false) // B2-client / free-repeat seat (₹0 revenue; cost still applies)
  finalPriceInrMinor        BigInt             @default(0) // billed price (paise) — an INPUT: varies per deal (EMI / negotiation)
  paidAmountInrMinor        BigInt             @default(0) // cash collected (paise); balance = paid − final
  paymentMethod             String? // "UPI", "Credit Card", "German Bank", "UPI · 6 EMI"…
  nextDueDate               DateTime?          @db.Date
  // Costs are DERIVED from the product via the level cost model (lib/gn-workshop-pricing).
  // These override the model only for genuine exceptions (null → use the model). Ad spend
  // is DERIVED at read time: workshop ad-set spend ÷ its AD conversions.
  booksCostOverrideInrMinor BigInt?
  tutorCostOverrideInrMinor BigInt?
  referralInrMinor          BigInt             @default(0)
  notes                     String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([workshopId])
  @@map("gn_workshop_conversion")
}

// ───────────────────────────── Cross-cutting ─────────────────────────────

// Daily ECB rate cache (frankfurter.app). One row per day; each money record
// stamps the rate it used so history never shifts.
model FxRate {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  inrPerEur Decimal  @db.Decimal(14, 6)
  provider  String   @default("frankfurter.app")
  fetchedAt DateTime @default(now())

  @@map("fx_rate")
}

// ───────────────────────────── Invites ─────────────────────────────
// Public sign-up is off: an Admin provisions the account, and the person sets their own
// password through a single-use link. Nobody — not even the Admin who invited them —
// ever knows their password.
//
// Only the SHA-256 of the token is stored, so a leaked database row cannot be redeemed.
// One row per user (`userId @unique`): re-inviting replaces the old token, which
// instantly invalidates any link already sent.
model UserInvite {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation("UserInviteFor", fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime? // set once redeemed — a link is good for exactly one use
  createdById String?
  createdBy   User?     @relation("UserInviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([expiresAt])
  @@map("user_invite")
}

// ───────────────────────────── Founder console — goals & rewards ─────────────────────────────
// The founder steers the team with GOALS ("₹12L revenue this quarter", "Asma: 40 discovery
// calls in July") and pays for outcomes with REWARD RULES ("30-day streak → ₹2,000").
//
// Neither stores progress. A goal's actual and a rule's qualifiers are DERIVED on read from
// the same append-only history the Arena scores (daily logs, stage moves, milestone logs), so
// nothing here can drift out of sync with the work that was actually done.

enum GoalScope {
  COMPANY // judged on the whole team's combined total
  USER // judged on one person's total
}

enum GoalPeriod {
  MONTH
  QUARTER
  YEAR
}

model Goal {
  id            String       @id @default(cuid())
  name          String
  // A key from GOAL_METRICS in src/lib/goals.ts (e.g. "wins", "xp", "revenueInr"). Text, not an
  // enum: the vocabulary is derived from the gamification engine, and adding a metric there
  // shouldn't force a database migration.
  metric        String
  scope         GoalScope    @default(COMPANY)
  teamProfileId String? // set when scope = USER
  teamProfile   TeamProfile? @relation(fields: [teamProfileId], references: [id], onDelete: Cascade)
  period        GoalPeriod   @default(MONTH)
  periodStart   DateTime     @db.Date // first day of the month / quarter / year
  targetValue   Decimal      @db.Decimal(16, 2)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([active, periodStart])
  @@index([teamProfileId])
  @@map("goal")
}

enum RewardKind {
  BONUS
  COMMISSION
  PERK // a thing, not a payout — amounts stay zero
}

enum RewardGrantStatus {
  PENDING // auto-detected, waiting on the founder
  APPROVED // founder said yes; not yet paid out
  DECLINED // founder said no — never re-offered
  PAID
}

model RewardRule {
  id             String     @id @default(cuid())
  name           String
  description    String
  kind           RewardKind @default(BONUS)
  active         Boolean    @default(true)
  // A RewardTrigger from src/lib/rewards.ts, validated by rewardTriggerSchema on write.
  trigger        Json
  roles          Role[] // empty = every role plays
  amountInrMinor BigInt     @default(0) // paise
  amountEurMinor BigInt     @default(0) // cents
  perkLabel      String? // what they get when kind = PERK
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  grants RewardGrant[]

  @@index([active])
  @@map("reward_rule")
}

// One person, one rule, one period. `periodKey` is derived from the trigger (a badge key, a
// level, a month…) — see src/lib/rewards.ts. The unique constraint below is what makes a
// re-scan idempotent: re-deriving every qualification in history inserts nothing new, so a
// rule can be edited and rescanned without ever double-paying, and a DECLINED grant stays
// declined instead of reappearing as PENDING.
model RewardGrant {
  id             String            @id @default(cuid())
  ruleId         String
  rule           RewardRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  teamProfileId  String
  teamProfile    TeamProfile       @relation(fields: [teamProfileId], references: [id], onDelete: Cascade)
  periodKey      String
  qualifiedOn    DateTime          @db.Date
  reason         String
  status         RewardGrantStatus @default(PENDING)
  // Amounts are copied off the rule and the rate stamped at grant time, so later edits to the
  // rule (or a move in the FX rate) never re-price what someone already earned.
  amountInrMinor BigInt            @default(0)
  amountEurMinor BigInt            @default(0)
  fxRateUsed     Decimal           @db.Decimal(14, 6)
  decidedById    String?
  decidedBy      User?             @relation("RewardGrantDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([ruleId, teamProfileId, periodKey])
  @@index([status, qualifiedOn])
  @@index([teamProfileId])
  @@map("reward_grant")
}

// Small key/value store: runway growth-rate override, ingest feature flags, etc.
// Founder-console keys: "sectionsConfig" (nav layout + role defaults),
// "gamificationRulesets" (the effective-dated XP/level/badge/quest rules).
model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_setting")
}

// ───────────────────────────── Wave-2 — WhatsApp (WATI) ─────────────────────────────
// Outbound WhatsApp via the WATI Business API BSP (the "Wave-2, gated on Ameen's sign-off"
// messaging the Wave-1 comments anticipated). Everything here is INERT unless WATI_ENABLED
// is set AND credentials + template names are configured: with the flag off every send is a
// no-op that still writes a SKIPPED row so the history is honest. Business-initiated messages
// are always pre-approved WhatsApp *templates* (24h-window rule); numbers are stored normalized
// (digits + country code) and STOP replies write a WhatsAppOptOut that blocks all future sends.

enum WhatsAppDirection {
  OUTBOUND
  INBOUND
}

// One value per lifecycle touchpoint (§ "all touchpoints"). MANUAL = a one-off send a human
// triggered from a section row; the rest are the automatic reminder cadence.
enum WhatsAppKind {
  DISCO_REMINDER // funnel: nudge an un-booked lead to book the discovery call
  BOOKING_CONFIRMATION // a slot was just booked
  BOOKING_REMINDER // pre-call reminder (~24h / ~1h before the slot)
  NO_SHOW_FOLLOWUP // missed the call — rebook
  PAYMENT_REMINDER // overdue pending payment / receivable
  EMI_PRE_DUE // instalment falls due in N days — the reminder that lands BEFORE the due date
  CHECKIN_NUDGE // student coaching check-in due
  SPRINT_MISS_NUDGE // student missed a sprint-week target
  AGREEMENT_SEND // coaching agreement is ready — carries the tokenized signing link
  AGREEMENT_OTP // 6-digit code binding the signature to control of this number
  AGREEMENT_REMINDER // an issued agreement is still unsigned
  // The countersigned copy, sent back the moment the student signs. Its OWN kind, not a reuse of
  // AGREEMENT_SEND: one WATI template is bound per kind, and that template carries the *signing*
  // link — the student would receive the wrong text and the section badges would misattribute the
  // send. This is also the row COMPLETED is derived from (see lib/agreement-state.ts).
  AGREEMENT_COPY // executed agreement — carries the link to the sealed, countersigned PDF
  MANUAL // free-form / manual send from a section
  // ── Outreach Specialist SOP (Steps 3–21). One kind per SOP message, deliberately.
  // The app binds exactly ONE WATI template per kind, so collapsing two SOP steps onto one kind
  // would send the wrong text for one of them. Nine SOP messages → nine kinds → nine templates.
  SOP_INTRO // Step 3  — WhatsApp introduction, immediately after opt-in
  SOP_FOLLOWUP // Step 6  — call not booked at the 2-hour check
  SOP_DISCO_WELCOME // Step 13 — qualified YES/MAYBE, disco call booked
  SOP_DISCO_CONFIRM_1 // Step 14 — ≥36h before the disco call
  SOP_DISCO_CONFIRM_2 // Step 15 — ≥24h before, no reply to Step 14
  SOP_DISCO_CANCEL // Step 16 — ≥12h before, unconfirmed after two calls
  SOP_SSS_CONFIRM_1 // Step 19 — ≥24h before the SSS, carries the personalized video
  SOP_SSS_CONFIRM_2 // Step 20 — ≥12h before the SSS, no reply to Step 19
  SOP_SSS_CANCEL // Step 21 — ≥10h before the SSS, still unconfirmed
  // ── Bookings confirmation loop (Module E). The in-house Bookings section's own confirm-or-cancel
  // cadence, independent of the Outreach SOP ladder above (which runs off a separate OutreachJourney).
  BOOKING_CONFIRM_REQUEST // asks the prospect to reply YES to hold their upcoming slot
  BOOKING_RESCHEDULED // their call was moved to a new time (manual postpone OR promoted-up)
  BOOKING_AUTO_CANCELLED // no confirmation in time — slot released, invite to rebook
  // ── SSS (sales) call calendar. The founder-run session; server/sss-slots.ts.
  SSS_RESCHEDULED // their SSS was moved to a new time (founder blocked the slot/day, or a manual/drag move)
}

enum WhatsAppStatus {
  SKIPPED // flag off / unconfigured / opted-out / deduped — nothing left the app
  QUEUED
  SENT // accepted by WATI
  DELIVERED // WATI delivery callback
  READ // WATI read callback
  REPLIED // prospect replied (inbound) — "WhatsApp confirmed" (SALES-LOGIC §2)
  FAILED
}

// Append-only send/receive log. Doubles as the idempotency source (sentRecently checks the
// last row for a kind+target) and the per-row status badge shown across the sections.
model WhatsAppMessage {
  id            String            @id @default(cuid())
  direction     WhatsAppDirection @default(OUTBOUND)
  kind          WhatsAppKind
  status        WhatsAppStatus    @default(QUEUED)
  toNumber      String // normalized (digits incl. country code, no '+')
  templateName  String? // WATI approved template used (null for inbound / free text)
  body          String? // rendered summary (outbound) or message text (inbound)
  params        Json? // template variables sent, for audit/debug
  watiMessageId String? // WATI id — matched by the status-callback webhook
  error         String? // failure reason when status = FAILED

  // Optional links to whatever this message was about (all SetNull — a message row must
  // survive deletion of the lead/student it referenced, like the rest of the audit tables).
  leadId           String?
  lead             Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  studentId        String?
  student          Student?        @relation(fields: [studentId], references: [id], onDelete: SetNull)
  bookingRequestId String?
  bookingRequest   BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)
  pendingPaymentId String?
  pendingPayment   PendingPayment? @relation(fields: [pendingPaymentId], references: [id], onDelete: SetNull)
  agreementId      String?
  agreement        Agreement?      @relation(fields: [agreementId], references: [id], onDelete: SetNull)

  sentById String? // the admin/user who triggered a manual send (null = automatic)
  sentBy   User?   @relation("WhatsAppSentBy", fields: [sentById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, createdAt])
  @@index([leadId])
  @@index([studentId])
  @@index([bookingRequestId])
  @@index([pendingPaymentId])
  @@index([agreementId])
  @@index([watiMessageId])
  @@index([toNumber])
  @@map("whatsapp_message")
}

// Phone-keyed opt-out (WhatsApp STOP / DPDP + GDPR). Checked before every send; written by
// the inbound webhook on a STOP-style reply and toggleable by Admin in the WhatsApp settings.
model WhatsAppOptOut {
  phone     String   @id // normalized, same shape as WhatsAppMessage.toNumber
  reason    String?
  createdAt DateTime @default(now())

  @@map("whatsapp_opt_out")
}

// ─────────────────────────────── Agreements (e-signature) ───────────────────────────────
//
// The founder fills a field form, signs, and WhatsApps a tokenized link; the student verifies a
// one-time code sent to the same number, signs on a canvas, and the PDF is rendered ONCE and
// sealed into `pdfBytes`.
//
// Two independent integrity claims, because they answer different questions:
//   dataSha256 — SHA-256 of the canonical JSON of `data` + `templateVersion`. Deterministic and
//                reproducible forever: it proves WHAT WAS AGREED. Printed on every page.
//   pdfSha256  — SHA-256 of the sealed bytes. It proves THE STORED ARTIFACT IS UNTOUCHED.
//                It is NOT reproducible: PDFKit stamps a creation date and document id, so
//                re-rendering identical data yields different bytes. Never re-render to verify.
//
// `data` is a frozen snapshot on purpose. The document must show what was true at signing, so
// rendering never joins back to the mutable Student row. It also carries the two fields the rest
// of the schema has no home for: the student's postal address and the programme batch.

enum AgreementStatus {
  DRAFT // founder is still editing; no token exists
  SENT // countersigned + link delivered; awaiting the student
  VIEWED // the student opened the link at least once
  SIGNED // sealed — pdfBytes + pdfSha256 are set and never change
  DECLINED // the student explicitly refused
  VOIDED // superseded or cancelled by the founder
  EXPIRED // the token's TTL elapsed unsigned
}

// Append-only trail. This IS the audit certificate: without it a canvas squiggle proves nothing.
enum AgreementEventType {
  CREATED
  ISSUED // founder countersigned and sent
  DELIVERY_SENT // handed to WATI
  DELIVERY_SKIPPED // WATI off / opted-out / no valid number — the founder must be told
  VIEWED
  OTP_SENT
  OTP_VERIFIED
  OTP_FAILED
  SIGNED
  DECLINED
  VOIDED
  COPY_DOWNLOADED
}

model Agreement {
  id              String          @id @default(cuid())
  documentNo      String          @unique // human reference, printed on every page: B2-GM-2026-0001
  templateVersion String // git-pinned renderer, e.g. "guided-v3"
  status          AgreementStatus @default(DRAFT)

  // Who it is for. SetNull like every other audit link: a signed agreement outlives its student row.
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  data       Json // frozen AgreementData — validated by agreementDataSchema, never re-joined
  dataSha256 String // canonical-JSON hash of (data + templateVersion)

  // Signing link. Same shape as UserInvite: only the SHA-256 lands in the database, so a leaked
  // row cannot be redeemed. `signedAt` doubles as the single-use burn marker (compare-and-set).
  tokenHash String?   @unique
  expiresAt DateTime?

  issuedById          String?
  issuedBy            User?     @relation("AgreementIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  issuedAt            DateTime?
  founderSignedAt     DateTime?
  founderSignaturePng Bytes?
  founderDevice       Json? // same shape as signerDevice, captured when the founder countersigns

  signedAt            DateTime? // also the burn marker — never set twice
  studentSignaturePng Bytes?
  // How the signature was physically made. Three parts, and the distinction is the whole point:
  // what the browser CLAIMS about itself, how the strokes were actually drawn, and — the only
  // half a disputing counterparty cannot rewrite — the IP and User-Agent our server OBSERVED.
  // See src/lib/device.ts. Frozen by the seal trigger; printed on the certificate.
  signerDevice        Json?
  declinedAt          DateTime?
  declineReason       String?
  voidedAt            DateTime?

  // OTP that binds the signature to control of the delivery number. Hashed, single-window,
  // attempt-capped. Cleared on success so a replayed code is worthless.
  otpHash      String?
  otpExpiresAt DateTime?
  otpAttempts  Int       @default(0)

  // The sealed artifact. Written exactly once, at signing. `bytea` rather than object storage:
  // link-only delivery means no public URL is ever needed, and the document carries the student's
  // home address and B2's IBANs. NEVER select pdfBytes in a list query.
  pdfBytes  Bytes?
  pdfSha256 String?
  pdfSize   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events           AgreementEvent[]
  whatsappMessages WhatsAppMessage[]

  @@index([status, createdAt])
  @@index([studentId])
  @@index([leadId])
  @@index([expiresAt])
  @@map("agreement")
}

// Append-only (DB trigger, see the agreements migration). No updatedAt — matches milestone_log,
// signal_change_log and the rest of the immutable-history tables.
model AgreementEvent {
  id          String             @id @default(cuid())
  agreementId String
  agreement   Agreement          @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  type        AgreementEventType
  ip          String?
  userAgent   String?
  meta        Json?
  createdAt   DateTime           @default(now())

  @@index([agreementId, createdAt])
  @@map("agreement_event")
}

// ───────────────────────── Accounting engine (SPEC §10) ─────────────────────────
//
// The double-entry general ledger. Finance and Cash Health are the *face*; this is
// the *engine*. Every money figure on every screen must trace to a balanced entry
// here — the UI never writes a balance directly (SPEC §10.1, principle 3).
//
// WHY THE NAME `LedgerAccount` AND NOT `Account`: `Account` is Better Auth's OAuth /
// credentials table (see `model Account`, @@map("account")). The chart of accounts is
// a completely different thing that happens to want the same word.
//
// MULTI-CURRENCY RULE (SPEC §10.1): a line carries its own currency and the FX rate at
// transaction time; the entry balances in the BASE currency (INR paise). We never
// re-derive history from today's rate. `baseDebitMinor`/`baseCreditMinor` are the
// INR-equivalent at `fxRate`, and Σbase-debits = Σbase-credits is enforced by a
// deferred constraint trigger at COMMIT — not just in application code.

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum Currency {
  INR
  EUR
}

enum JournalEntryStatus {
  POSTED
  VOID
}

// Where an entry came from. `(sourceType, sourceId)` is unique, so a given Income row
// can never be posted to the ledger twice — the guard against double-counting revenue.
enum LedgerSourceType {
  INCOME
  EXPENSE
  MANUAL
  OPENING_BALANCE
  FX_REVALUATION
  // Added so Payments-module money (currently disconnected from the ledger — see
  // docs/BUILD_CHECKLIST.md §7) has somewhere to post to. Adding these values is additive
  // and safe: forbid_duplicate_live_source() keys off sourceType/sourceId generically and
  // needs no change (see migrations/20260710143908_ledger_source_guard).
  INVOICE
  PAYMENT
}

// Chart of accounts, seeded for B2 in `prisma/chart-of-accounts.ts` (SPEC §10.1).
// `code` is the stable key the posting engine resolves against — never the name,
// which the founder may reword.
model LedgerAccount {
  id       String            @id @default(cuid())
  code     String            @unique
  name     String
  type     LedgerAccountType
  // null = accepts any currency (income/expense accounts); set = a real-world
  // account denominated in one currency, e.g. Bank (EUR).
  currency Currency?
  // COGS is a *reporting* flag on the account, mirroring Expense.isCogs, so gross
  // profit is a ledger slice rather than a second source of truth.
  isCogs   Boolean           @default(false)
  parentId String?
  parent   LedgerAccount?    @relation("LedgerAccountTree", fields: [parentId], references: [id], onDelete: SetNull)
  children LedgerAccount[]   @relation("LedgerAccountTree")
  archived Boolean           @default(false)
  sortKey  Int               @default(0)

  lines JournalLine[]

  @@index([type, code])
  @@map("ledger_account")
}

// A balanced journal entry. Append-only: corrections are made by VOIDing and posting a
// reversal (`reversalOfId`), never by editing history (SPEC §10.1, §12 audit rule).
model JournalEntry {
  id           String             @id @default(cuid())
  date         DateTime           @db.Date
  narration    String
  status       JournalEntryStatus @default(POSTED)
  sourceType   LedgerSourceType
  sourceId     String?
  // A VOID entry points at the entry it reverses; the reversal mirrors every line.
  reversalOfId String?            @unique
  reversalOf   JournalEntry?      @relation("JournalReversal", fields: [reversalOfId], references: [id], onDelete: SetNull)
  reversedBy   JournalEntry?      @relation("JournalReversal")
  postedById   String?
  postedBy     User?              @relation("JournalEntryPostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  createdAt    DateTime           @default(now())

  lines JournalLine[]

  // At most one *live* (POSTED) entry per source row — enforced by the
  // `forbid_duplicate_live_source` trigger, not by a unique index.
  //
  // A plain UNIQUE(sourceType, sourceId) would be wrong: editing an Income voids its
  // entry and posts a restated one, and the voided original keeps its sourceId so the
  // trail stays traceable. The correct constraint is "unique among POSTED rows", i.e. a
  // partial index — which Prisma cannot express and would try to DROP on the next
  // `migrate dev`. Prisma does not manage triggers, so the guard lives there instead.
  @@index([sourceType, sourceId])
  @@index([date])
  @@index([status, date])
  @@map("journal_entry")
}

// One side of one entry. Exactly one of debit/credit is non-zero (CHECK constraint).
model JournalLine {
  id        String        @id @default(cuid())
  entryId   String
  entry     JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId String
  account   LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  // Amounts as transacted, in `currency`'s minor units (paise / cents).
  debitMinor  BigInt   @default(0)
  creditMinor BigInt   @default(0)
  currency    Currency
  // INR per 1 unit of `currency`, stamped at transaction time. Always 1.0 for INR.
  fxRate      Decimal  @db.Decimal(14, 6)

  // The same amounts in base currency (INR paise). These are what must balance.
  baseDebitMinor  BigInt @default(0)
  baseCreditMinor BigInt @default(0)

  isCogs Boolean @default(false)

  @@index([entryId])
  @@index([accountId])
  @@map("journal_line")
}

// Admin closes a month; the posting engine then refuses any entry dated inside it,
// so a backdated edit can never silently restate a period Ameen has already read.
model PeriodLock {
  id         String   @id @default(cuid())
  // "YYYY-MM" in IST — the same key the Finance month picker uses.
  month      String   @unique
  lockedAt   DateTime @default(now())
  lockedById String?
  lockedBy   User?    @relation("PeriodLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  note       String?

  @@map("period_lock")
}

// Immutable, hash-chained audit log (SPEC §10.1, §3 "from day one").
//
// `hash = sha256(prevHash || canonicalJson(payload))`, so altering or deleting any
// historical row breaks every hash after it. `seq` gives the chain its order.
// Append-only at the DB level too — see the migration's forbid_mutation() trigger.
model AuditEntry {
  seq        BigInt   @id @default(autoincrement())
  at         DateTime @default(now())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String
  payload    Json
  prevHash   String
  hash       String   @unique

  @@index([entityType, entityId])
  @@index([at])
  @@map("audit_entry")
}

// Who did what, when — every write in the app, in one place.
//
// Deliberately NOT AuditEntry: that chain exists to prove the finance history hasn't been
// tampered with, and it pays for that with a global advisory lock per append plus an O(n)
// verify the Ledger page runs on load. Feeding it a row per dial would serialise every
// writer on one lock and make that verify walk grow forever. This table is the plain
// counterpart — a row per action, written outside the caller's transaction, indexed for
// the founder's filters. Finance keeps writing to BOTH: the chain for proof, this for the feed.
//
// Append-only by the same forbid_mutation() trigger the other history tables use: the record
// of what Asma did at 3pm is worth nothing if it can be edited at 4pm.
//
// actorName/actorRole are denormalised on purpose. `actor` is SetNull on delete, so without
// the copy, removing a user would silently blank their entire history — the one moment the
// log matters most. The copy is what was true AT THE TIME, which is also the honest answer
// when someone's role changes later.
model ActivityLog {
  id         String   @id @default(cuid())
  // Server-stamped instant, never from the client. Rendered in IST (CONTEXT §6).
  at         DateTime @default(now())
  actorId    String?
  actor      User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName  String
  actorRole  String
  // Dotted verb: "call.log", "lead.update", "finance.income.create".
  action     String
  // Section key (sections.ts) — the founder's filter is "show me Pipeline", not "show me lead.*".
  section    String
  entityType String
  entityId   String
  // One human sentence, composed at the call site where the names are already loaded:
  // "Logged a call with Priya Sharma — SPOKE". The feed reads it verbatim, so the founder
  // never has to decode an id.
  summary    String
  // Optional structured detail: { before, after, changed: [...] } for edits, free shape otherwise.
  meta       Json?

  @@index([at])
  @@index([actorId, at])
  @@index([section, at])
  @@index([entityType, entityId])
  @@map("activity_log")
}

// ───────────────────────────── Resume Studio ─────────────────────────────
// Founder-configurable CV builder. A Resume stores its structured content as JSON
// (shape = ResumeData in src/lib/resume-types.ts); the founder's template — which
// sections show, in what order, styling and the ATS rubric — lives in
// AppSetting("resumeTemplateConfig"). Each Resume renders to DOCX and PDF, and can
// be reviewed against a target JD by the Claude API (keys-off seam in lib/anthropic.ts);
// each review is kept so the coach can re-run it as often as they like and compare.
// ownerUserId / leadId are soft references (no FK) to keep this module self-contained.

model Resume {
  id          String         @id @default(cuid())
  title       String
  language    String         @default("EN") // "EN" | "DE"
  data        Json // ResumeData
  ownerUserId String?
  ownerName   String? // denormalised creator name for the list
  leadId      String? // optional soft link to a CRM lead/contact
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  reviews     ResumeReview[]

  @@index([ownerUserId])
  @@index([leadId])
  @@map("resume")
}

// One ATS review of a resume against a JD. provider = "ai" (Claude) or
// "deterministic" (the offline analyser fallback). result = structured findings JSON.
model ResumeReview {
  id           String   @id @default(cuid())
  resumeId     String
  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jdText       String
  provider     String   @default("ai")
  model        String?
  scoreOverall Int      @default(0) // 0-100 ATS match
  result       Json
  createdAt    DateTime @default(now())

  @@index([resumeId])
  @@map("resume_review")
}

// ═══════════════ Outreach Specialist SOP (Script_for_Outreach_Specialist.docx, Steps 1–23) ═══════
// The 23-step lead lifecycle: opt-in → WhatsApp intro → booking chase → BANT qualification →
// Disco confirmation → handoff to the Discovery Specialist → SSS confirmation.
//
// Design: the SOP is a HUMAN-EXECUTED process, so the engine's job is to say WHAT to send, to
// WHOM, WHEN — not to send behind the specialist's back. Every step materialises as an
// OutreachStepLog row with a rendered body the specialist can read, copy and mark sent. Admin can
// flip individual steps to auto-send (AppSetting "outreachConfig"); every step is manual by
// default. See src/lib/outreach-sop.ts (templates) and src/lib/outreach-engine.ts (the ladder).

/// One actionable SOP step. Each value is exactly one row per journey (see the @@unique on
/// OutreachStepLog), which is what makes the ladder idempotent — re-running the engine can never
/// double-send. Step 16's two required call attempts are separate values for the same reason.
enum OutreachStep {
  INTRO_WHATSAPP // Step 3  — immediately after opt-in (target <5 min)
  FIRST_CALL // Step 4  — call right after the intro message
  CHECK_1 // Step 5  — wait 2h, then run the Step 10 booking check
  FOLLOWUP_WHATSAPP // Step 6  — not booked at check 1
  CHECK_2 // Step 7  — wait 1h, then re-run the booking check
  FOLLOWUP_CALL // Step 8  — not booked at check 2
  FINAL_CHECK // Step 9  — wait 2h; not booked → IGNORE
  BANT_QUALIFICATION // Step 11 — score the booking against the New BANT model
  KEY_METRICS_TRANSFER // Step 12 — transfer 6 fields + assign Touchpoint/Disco owners
  DISCO_WELCOME // Step 13 — immediately on Qualified = YES/MAYBE
  DISCO_CONFIRM_1 // Step 14 — at least 36h before the disco call
  DISCO_CONFIRM_2 // Step 15 — at least 24h before, only if Step 14 got no reply
  DISCO_CONFIRM_CALL_1 // Step 16 — first of two required call attempts
  DISCO_CONFIRM_CALL_2 // Step 16 — second required call attempt
  DISCO_CANCEL_MSG // Step 16 — at least 12h before, only after both calls failed
  DISCO_CANCEL // Step 17/18 — cancel the calendar appointment, mark the row RED
  SSS_CONFIRM_1 // Step 19 — at least 24h before the SSS call (carries the personalized video)
  SSS_CONFIRM_2 // Step 20 — at least 12h before, only if Step 19 got no reply
  SSS_CANCEL_MSG // Step 21 — at least 10h before, still unconfirmed
  SSS_CANCEL // Step 22/23 — cancel the SSS appointment, mark the row RED
}

/// Where a prospect sits in the SOP. Every branch in the SOP terminates in one of
/// IGNORED / CANCELLED / CLOSED_NOT_HQ / COMPLETED — there are no dead ends (checklist §S).
enum OutreachPhase {
  OPT_IN // Step 1–2: captured, not yet contacted
  BOOKING_CHASE // Steps 3–9: chasing the booking
  QUALIFICATION // Steps 11–12: booked, awaiting BANT + Key Metrics transfer
  DISCO_CONFIRMATION // Steps 13–16: qualified, chasing confirmation
  AWAITING_DISCO // confirmed; the Discovery Specialist runs the call
  HANDOFF // Step 18: disco done, awaiting the Highly Qualified verdict
  SSS_CONFIRMATION // Steps 19–22: HQ = YES, chasing SSS confirmation
  COMPLETED // SSS confirmed — the outreach process succeeded
  IGNORED // Step 9: never booked. Dormant, NOT deleted — stays in records
  CANCELLED // Step 17/22: appointment cancelled
  CLOSED_NOT_HQ // Step 18: Highly Qualified = NO — the outreach process ends here
}

/// The SOP's "Qualified" column. Derived from the BANT score by qualifiedFromBant(), which is the
/// single source of truth (src/lib/outreach-sop.ts) — YES → Step 13, MAYBE → Step 13, NO → Step 17.
enum QualifiedVerdict {
  YES // Qualified
  MAYBE // Cannot judge
  NO // Not qualified
}

enum OutreachStepStatus {
  DUE // materialised and waiting on the specialist (or the auto-sender)
  SENT // executed — renderedBody holds the exact text that went out
  SKIPPED // deliberately passed over (specialist chose to, or the branch closed)
  FAILED // auto-send attempted and the provider rejected it
  SUPERSEDED // overtaken by events (e.g. prospect confirmed before this reminder was due)
}

enum OutreachChannel {
  WHATSAPP
  CALL
  SYSTEM // internal checks (Step 5/7/9/10) and calendar actions (Step 17/22)
}

/// One prospect's walk through the SOP. Exactly one per Lead. Holds the SOP's own columns — the
/// ones "Key Metrics Sales B2_2026.xlsx" carries and the CRM has no home for.
model OutreachJourney {
  id        String          @id @default(cuid())
  leadId    String          @unique
  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // Set when the Step 10 cross-check matches this lead to a booking (by normalized email/phone).
  bookingId String?         @unique
  booking   BookingRequest? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  phase OutreachPhase @default(OPT_IN)

  // Step 1–2. optInAt is the SLA baseline; it mirrors Lead.createdAt but is held here so the
  // journey is self-contained and the clock can be corrected if a webhook replays late.
  optInAt     DateTime
  // Step 2's "Time Contacted" column. Stored as a UTC instant, entered and displayed in IST.
  contactedAt DateTime?

  // Step 11/12 — qualification. Auditable: who decided, when, and off which score (checklist §K).
  qualified       QualifiedVerdict?
  qualifiedAt     DateTime?
  qualifiedById   String?
  qualifiedBy     User?             @relation("OutreachQualifiedBy", fields: [qualifiedById], references: [id], onDelete: SetNull)
  bantScoreAtQual Float? // the bantAvg the verdict was taken on — survives a later re-tune

  // Step 12 — the two Key Metrics assignment dropdowns.
  respTouchpointId String?
  respTouchpoint   User?   @relation("OutreachRespTouchpoint", fields: [respTouchpointId], references: [id], onDelete: SetNull)
  respDiscoId      String?
  respDisco        User?   @relation("OutreachRespDisco", fields: [respDiscoId], references: [id], onDelete: SetNull)

  // Step 14/15 — the Key Metrics "WhatsApp Sent" / "WhatsApp Confirmed" columns.
  // sent flips on actual delivery, never on scheduling (checklist §N).
  whatsappSent        Boolean   @default(false)
  whatsappSentAt      DateTime?
  whatsappConfirmed   Boolean   @default(false)
  whatsappConfirmedAt DateTime?

  // Step 19/20 — the Key Metrics "Sales Call Confirmed" column.
  salesCallConfirmed   Boolean   @default(false)
  salesCallConfirmedAt DateTime?

  // Step 18 — written by the Discovery Specialist only (enforced in outreach-actions.ts).
  highlyQualified   Boolean?
  highlyQualifiedAt DateTime?

  // Step 19 — the SSS appointment instant (UTC), set when the Discovery Specialist books it.
  sssAt DateTime?

  // Cross-cutting — the Zoom link pulled from the Discovery Specialist's calendar (§R).
  zoomLink String?

  // Steps 16/18/21/23 — the "mark the row RED" flag. A presentation flag on its own field so it
  // can never silently overwrite a status column (checklist §N).
  redFlag       Boolean @default(false)
  redFlagReason String?

  ignoredAt    DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps   OutreachStepLog[]
  // The SSS slot this prospect is booked into (null unless an SSS is scheduled via the
  // calendar). journey.sssAt is kept in sync with the slot's startsAt so the SSS confirmation
  // ladder (steps 19–21, anchored on sssAt) keeps working through any reschedule.
  sssSlot SssSlot?          @relation("SssSlotJourney")

  @@index([phase])
  @@index([contactedAt])
  @@index([qualified])
  @@map("outreach_journey")
}

/// One SOP step for one prospect. APPEND-ONLY in spirit: a row is created when the step becomes
/// due and is only ever transitioned DUE → SENT/SKIPPED/FAILED/SUPERSEDED.
///
/// The @@unique([journeyId, step]) is the idempotency guarantee the checklist asks for repeatedly
/// (§C "no duplicate sends", §F "doesn't resend if already sent once"). It is a DB constraint, not
/// a read-then-write check, so concurrent cron runs cannot both materialise the same step.
model OutreachStepLog {
  id        String          @id @default(cuid())
  journeyId String
  journey   OutreachJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  step    OutreachStep
  status  OutreachStepStatus @default(DUE)
  channel OutreachChannel

  /// When the SOP says this step should happen. For the Disco/SSS ladders this is computed
  /// backward from the appointment instant (T-36h, T-24h, ...), not forward from enrollment.
  dueAt   DateTime
  actedAt DateTime?

  actedById String?
  actedBy   User?   @relation("OutreachStepActedBy", fields: [actedById], references: [id], onDelete: SetNull)

  /// The exact message text that went out, variables already resolved. This is the audit record —
  /// re-rendering later could differ if a template is edited, so we keep what was actually sent.
  renderedBody String?

  /// For CALL steps: the SOP's Yes/No branch outcome. For SYSTEM checks: the check result.
  outcome String?

  /// Set when a step auto-sends through WATI, so the log joins back to the delivery record.
  whatsAppMessageId String?

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([journeyId, step])
  @@index([status, dueAt])
  @@index([journeyId])
  @@map("outreach_step_log")
}
