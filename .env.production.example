# B2 Consultants — VPS production environment.
#
#   cp .env.production.example .env.production   (on the VPS, then fill in)
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# .env.production is git-ignored and docker-ignored — it must NEVER be committed and
# never lands in an image layer. Keep it 0600 and owned by the deploy user:
#   chmod 600 .env.production
#
# Everything under "REQUIRED" is validated at container boot by src/lib/env.ts. Get one
# wrong and the app refuses to start with a specific message — that is intentional. The
# alternative (the old behaviour) was silently emailing localhost links to real students.

# ─────────────────────────── REQUIRED ───────────────────────────

# --- Database: Supabase (project vyuzqkzujjbgccfjhjcr, ap-southeast-1) ---
#
# READ THIS BEFORE PASTING FROM THE SUPABASE DASHBOARD. The URL the dashboard shows
# first is the DIRECT one (db.<ref>.supabase.co). It is IPv6-only and will NOT work
# from most VPS hosts. Use the POOLER hostname for both vars below:
#
#   username : postgres.<project-ref>          (NOT plain "postgres")
#   host     : aws-0-ap-southeast-1.pooler.supabase.com
#   password : percent-encode it. An "@" MUST become %40, or the parser reads the
#              host as everything after the last @ and you get a nonsense DNS error.
#
# DATABASE_URL = transaction pooler, port 6543 — what the app uses at runtime.
#   connection_limit=1 is required with pgbouncer in transaction mode.
DATABASE_URL="postgresql://postgres.vyuzqkzujjbgccfjhjcr:PASSWORD_URL_ENCODED@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL = session pooler, port 5432 — used ONLY by `prisma migrate deploy`.
#   Migrations take a session-level advisory lock, which the 6543 pooler cannot hold.
DIRECT_URL="postgresql://postgres.vyuzqkzujjbgccfjhjcr:PASSWORD_URL_ENCODED@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- Public origin ---
# Must be the real https origin, with NO trailing slash. This is not just for auth:
# it is the base for password-reset links, invite links, agreement e-signing URLs and
# WhatsApp/booking links. Wrong value = broken links in real emails.
APP_DOMAIN="app.b2consultants.in"
BETTER_AUTH_URL="https://app.b2consultants.in"
# Where Let's Encrypt sends certificate-expiry warnings.
TLS_EMAIL="support@sirahdigital.in"

# --- Secrets: generate fresh, do NOT reuse the local dev values ---
#   openssl rand -base64 32
# Changing BETTER_AUTH_SECRET later signs every user out — set it once, keep it.
BETTER_AUTH_SECRET=""
# The only thing standing between the public internet and /api/cron/*.
CRON_SECRET=""

# ─────────────────────────── OPTIONAL ───────────────────────────
# All of these fail CLOSED: leave blank and the feature is simply off. Nothing breaks.

# Server timezone. The daily-log cutoff and SOP ladder are reasoned about in IST.
TZ="Asia/Kolkata"

FX_API_URL="https://api.frankfurter.app"

# --- Email (Resend) ---
# Drives password-reset / invite mail AND the automatic payment-due reminders (the daily
# cron emails students whose instalment is due within 3 days or overdue). Set a verified
# Resend sender and flip EMAIL_ENABLED to "true" to arm it; left off, the reminders still
# run and log who WOULD be mailed, but send nothing.
EMAIL_ENABLED="false"
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# --- WhatsApp (WATI) ---
WATI_ENABLED="false"
WATI_API_ENDPOINT=""
WATI_ACCESS_TOKEN=""
WATI_WEBHOOK_SECRET=""

# --- SMS (Twilio) ---
SMS_ENABLED="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""

# --- CV/JD review (Claude) ---
AI_REVIEW_ENABLED="false"
ANTHROPIC_API_KEY=""

# --- Inbound lead webhooks ---
# Pabbly is the live router today; point its B2 action at
#   https://<APP_DOMAIN>/api/leads/pabbly
PABBLY_WEBHOOK_SECRET=""
FLEXIFUNNELS_WEBHOOK_SECRET=""
META_VERIFY_TOKEN=""
META_APP_SECRET=""
META_PAGE_ACCESS_TOKEN=""
META_GRAPH_VERSION=""

# --- Deliberately NOT set ---
# REDIS_URL — there is no redis service and no worker process. automation-queue.ts
#   returns null without it and falls back to Postgres polling, which is the source of
#   truth regardless. Setting this without a running redis only produces error spam.
# SEED_* — seed scripts only, never read by the running app.
