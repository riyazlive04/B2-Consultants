# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/.next-prod/
# out-of-band verify builds (NEXT_DIST_DIR=.next-verify…) — throwaway, never committed
/.next-verify*
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local env — real secrets live here, never commit.
# Bare `.env` does NOT match `.env.production`, so list the whole family explicitly and
# re-admit the value-less templates. Without this, a `.env.production` holding the live
# Supabase password would be committable.
.env
.env.*
!.env.example
!.env.supabase.example
!.env.production.example

# no-Docker local Postgres (scripts/local-db.mjs)
/.pgdata/

# Supabase migration working dir (scripts/migrate-to-supabase.mjs).
# data.sql is a full plaintext dump: lead PII, student records, the ledger. Never commit.
/.migration/

# local dev noise — runtime logs never belong in the repo (dev server, cron, verify runs)
*.log
scripts/tmp/
